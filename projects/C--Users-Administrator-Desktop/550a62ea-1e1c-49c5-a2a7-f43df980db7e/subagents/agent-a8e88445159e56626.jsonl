{"parentUuid":"1ef7015b-e15e-4af9-97c9-4a0fc5769eab","isSidechain":true,"userType":"external","cwd":"C:\\Users\\Administrator\\Desktop","sessionId":"550a62ea-1e1c-49c5-a2a7-f43df980db7e","version":"2.1.71","gitBranch":"HEAD","agentId":"a8e88445159e56626","slug":"declarative-rolling-pike","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GwYZ6BzTrHtn4FBXPygdbS","type":"tool_result","content":"     1→using System;\n     2→using System.Collections.Generic;\n     3→using System.ComponentModel;\n     4→using System.Data;\n     5→using System.Drawing;\n     6→using System.Linq;\n     7→using System.Text;\n     8→using System.Windows.Forms;\n     9→\n    10→namespace NoiseTest\n    11→{\n    12→    public partial class FrmIO : Form\n    13→    {\n    14→        // 빠른 접근용 캐시\n    15→        private PictureBox[] _inPics = new PictureBox[24];   // pictureBox1..16\n    16→        private PictureBox[] _outPics = new PictureBox[24];  // pictureBox17..32\n    17→        private bool _updating = false;                      // 타이머 재진입 방지\n    18→\n    19→        public FrmIO()\n    20→        {\n    21→            InitializeComponent();\n    22→\n    23→            // 공통 원형 및 기본 배경\n    24→            for (int i = 1; i <= 48; i++)\n    25→            {\n    26→                var pic = FindPic(i);\n    27→                if (pic != null)\n    28→                {\n    29→                    MakeCircle(pic);\n    30→                    pic.BackColor = Color.Black; // OFF 기본\n    31→                }\n    32→            }\n    33→\n    34→            // IN (1..16) 레이블 및 배열 캐시\n    35→            for (int i = 1; i <= 24; i++)\n    36→            {\n    37→                var pic = FindPic(i);\n    38→                if (pic != null)\n    39→                {\n    40→                    SetupIoIndicator(pic, $\"IN{i - 1:D2}\");\n    41→                    _inPics[i - 1] = pic;\n    42→                }\n    43→            }\n    44→\n    45→            // OUT (17..32) 레이블, Tag, 클릭/포워딩, 배열 캐시\n    46→            for (int i = 25; i <= 48; i++)\n    47→            {\n    48→                var pic = FindPic(i);\n    49→                if (pic != null)\n    50→                {\n    51→                    int outIndex = i - 25; // 0~15\n    52→                    SetupIoIndicator(pic, $\"OUT{outIndex:D2}\");\n    53→                    pic.Tag = outIndex;\n    54→\n    55→                    pic.Click += pictureBoxOutput_Click;\n    56→\n    57→                    var lbl = GetOverlayLabel(pic);\n    58→                    if (lbl != null)\n    59→                    {\n    60→                        // 라벨 클릭도 동일 동작\n    61→                        lbl.Click += (s, e) => pictureBoxOutput_Click(pic, EventArgs.Empty);\n    62→                    }\n    63→\n    64→                    _outPics[outIndex] = pic;\n    65→                }\n    66→            }\n    67→\n    68→            // 타이머 연결 및 시작\n    69→            timer1.Interval = 100;\n    70→            timer1.Tick += timer1_Tick;   // ★ Tick 핸들러 연결\n    71→            timer1.Start();\n    72→        }\n    73→\n    74→        // ===== UI 헬퍼 =====\n    75→        private PictureBox FindPic(int idx)\n    76→            => this.Controls.Find($\"pictureBox{idx}\", true).FirstOrDefault() as PictureBox;\n    77→\n    78→        private void MakeCircle(PictureBox pic)\n    79→        {\n    80→            var gp = new System.Drawing.Drawing2D.GraphicsPath();\n    81→            gp.AddEllipse(0, 0, pic.Width - 1, pic.Height - 1);\n    82→            pic.Region = new Region(gp);\n    83→        }\n    84→\n    85→        private void SetupIoIndicator(PictureBox pic, string text)\n    86→        {\n    87→            // 원형 보장(다시 호출돼도 문제 없음)\n    88→            var gp = new System.Drawing.Drawing2D.GraphicsPath();\n    89→            gp.AddEllipse(0, 0, pic.Width - 1, pic.Height - 1);\n    90→            pic.Region = new Region(gp);\n    91→\n    92→            // 라벨(중복 추가 방지: 기존 있으면 교체)\n    93→            var old = GetOverlayLabel(pic);\n    94→            if (old != null) pic.Controls.Remove(old);\n    95→\n    96→            var lbl = new Label\n    97→            {\n    98→                Text = text,\n    99→                AutoSize = false,\n   100→                TextAlign = ContentAlignment.MiddleCenter,\n   101→                Dock = DockStyle.Fill,\n   102→                BackColor = Color.White,   // OFF 배경\n   103→                ForeColor = Color.Black,   // OFF 글자\n   104→                Font = new Font(\"Segoe UI\", 8, FontStyle.Bold),\n   105→                Name = \"OverlayLabel\"\n   106→            };\n   107→            pic.Controls.Add(lbl);\n   108→        }\n   109→\n   110→        private static Label GetOverlayLabel(PictureBox pic)\n   111→            => pic?.Controls.OfType<Label>().FirstOrDefault(l => l.Name == \"OverlayLabel\");\n   112→\n   113→        private void ApplyOnOffStyle(PictureBox pic, bool isOn)\n   114→        {\n   115→            if (pic == null) return;\n   116→\n   117→            // 픽쳐박스 배경(LED)\n   118→            pic.BackColor = isOn ? Color.Blue : Color.Black;\n   119→\n   120→            // 라벨 전경/배경\n   121→            var lbl = GetOverlayLabel(pic);\n   122→            if (lbl != null)\n   123→            {\n   124→                if (isOn)\n   125→                {\n   126→                    lbl.BackColor = Color.Black; // ON: 배경 검정\n   127→                    lbl.ForeColor = Color.White; // ON: 글자 흰색\n   128→                }\n   129→                else\n   130→                {\n   131→                    lbl.BackColor = Color.White; // OFF: 배경 흰색\n   132→                    lbl.ForeColor = Color.Black; // OFF: 글자 검정\n   133→                }\n   134→            }\n   135→        }\n   136→\n   137→        // ===== 출력 토글 클릭 =====\n   138→        private void pictureBoxOutput_Click(object sender, EventArgs e)\n   139→        {\n   140→            var pic = sender as PictureBox;\n   141→            if (pic == null) return;\n   142→            if (FrmMain.Io == null) return;\n   143→\n   144→            // 안전 파싱\n   145→            int index = -1;\n   146→            if (pic.Tag is int i) index = i;\n   147→            else if (!int.TryParse(pic.Tag + \"\", out index)) return;\n   148→            if (index < 0 || index > 24) return;\n   149→\n   150→            // 현재 상태 읽고 토글\n   151→            bool next = !FrmMain.Io.GetOutput(index);\n   152→            if (next)\n   153→            {\n   154→                FrmMain.Io.Do_On_Force(index);\n   155→                FrmMain.Io.Commit();\n   156→            }\n   157→            else\n   158→            {\n   159→                FrmMain.Io.Do_Off_Force(index);\n   160→                FrmMain.Io.Commit();\n   161→            }\n   162→\n   163→\n   164→            // 낙관적 UI 업데이트(워커가 실제 반영 전이라도 UI는 먼저 변경)\n   165→            ApplyOnOffStyle(pic, next);\n   166→        }\n   167→\n   168→        // ===== 주기 갱신(Timer) =====\n   169→        private void timer1_Tick(object sender, EventArgs e)\n   170→        {\n   171→            if (_updating) return;   // 재진입 방지\n   172→            _updating = true;\n   173→            try\n   174→            {\n   175→                var io = FrmMain.Io;\n   176→                if (io == null) return;\n   177→\n   178→                // 입력(0..15) → pictureBox1..16\n   179→                for (int i = 0; i < 25; i++)\n   180→                {\n   181→                    var pic = _inPics[i];\n   182→                    if (pic == null) continue;\n   183→\n   184→                    bool v = io.GetInput(i);\n   185→                    ApplyOnOffStyle(pic, v);\n   186→                }\n   187→\n   188→                // 출력(0..15) → pictureBox17..32\n   189→                for (int i = 0; i < 25; i++)\n   190→                {\n   191→                    var pic = _outPics[i];\n   192→                    if (pic == null) continue;\n   193→\n   194→                    bool v = io.GetOutput(i);\n   195→                    ApplyOnOffStyle(pic, v);\n   196→                }\n   197→            }\n   198→            catch (Exception ex)\n   199→            {\n   200→                // 표시만이므로 조용히 무시(필요시 로그)\n   201→                System.Diagnostics.Debug.WriteLine($\"[FrmIO] Timer Tick 예외: {ex.Message}\");\n   202→            }\n   203→            finally\n   204→            {\n   205→                _updating = false;\n   206→            }\n   207→        }\n   208→\n   209→        private void btnClose_Click(object sender, EventArgs e)\n   210→        {\n   211→            this.Close();\n   212→        }\n   213→    }\n   214→}\n   215→"}]},"uuid":"a4867796-95ec-4469-8f94-cdd6d5ebff4b","timestamp":"2026-03-11T04:46:45.177Z","sourceToolAssistantUUID":"1ef7015b-e15e-4af9-97c9-4a0fc5769eab"}
