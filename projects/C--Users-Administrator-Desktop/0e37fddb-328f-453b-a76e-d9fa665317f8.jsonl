f is_weekday(d):\n    return d.weekday() < 5  # Mon-Fri\n\ndef get_weekdays(year, month):\n    \"\"\"Get all weekdays in a month\"\"\"\n    days = []\n    d = date(year, month, 1)\n    while d.month == month:\n        if is_weekday(d):\n            days.append(d)\n        d += timedelta(days=1)\n    return days\n\nmonths = [5, 6, 7, 8, 9, 10, 11, 12]\n\nfor month in months:\n    weekdays = get_weekdays(2025, month)\n\n    # Pick which days have business trips (about 40-50% of days)\n    num_business = random.randint(int(len(weekdays) * 0.35), int(len(weekdays) * 0.50))\n    business_days = set(random.sample(range(len(weekdays)), min(num_business, len(weekdays))))\n\n    for i, day in enumerate(weekdays):\n        if i in business_days:\n            # Business trip day\n            trip = random.choice(business_trips)\n            dest_name, dest_addr, km, remark_opts = trip\n            remark = random.choice(remark_opts) if remark_opts else ''\n\n            all_entries.append({\n                'date': day,\n                'driver': DRIVER,\n                'type': '6.업무용(왕복)',\n                'from_class': '회사',\n                'from_name': COMPANY_NAME,\n                'from_addr': COMPANY_ADDR,\n                'to_class': '공항' if dest_name == '공항' else '거래처',\n                'to_name': dest_name,\n                'to_addr': dest_addr,\n                'km': km,\n                'remark': remark\n            })\n        else:\n            # Commute day\n            all_entries.append({\n                'date': day,\n                'driver': DRIVER,\n                'type': '5.출퇴근용(왕복)',\n                'from_class': '자택',\n                'from_name': '',\n                'from_addr': HOME_ADDR,\n                'to_class': '회사',\n                'to_name': COMPANY_NAME,\n                'to_addr': COMPANY_ADDR,\n                'km': COMMUTE_KM,\n                'remark': ''\n            })\n\n# Add 2027-01-01 entry (like original)\nall_entries.append({\n    'date': date(2027, 1, 1),\n    'driver': DRIVER,\n    'type': '5.출퇴근용(왕복)',\n    'from_class': '자택',\n    'from_name': '',\n    'from_addr': HOME_ADDR,\n    'to_class': '회사',\n    'to_name': COMPANY_NAME,\n    'to_addr': COMPANY_ADDR,\n    'km': COMMUTE_KM,\n    'remark': ''\n})\n\n# Now duplicate some business trip days to reach ~376 entries\n# Current count\ncurrent_count = len(all_entries)\nneeded = 376 - current_count\n\nif needed > 0:\n    # Add extra business trips on random weekdays\n    for month in months:\n        weekdays = get_weekdays(2025, month)\n        extras_this_month = needed // len(months) + (1 if month <= needed % len(months) + 4 else 0)\n\n        available_days = [d for d in weekdays if d.weekday() < 5]\n        extra_days = random.sample(available_days, min(extras_this_month, len(available_days)))\n\n        for day in extra_days:\n            trip = random.choice(business_trips)\n            dest_name, dest_addr, km, remark_opts = trip\n            remark = random.choice(remark_opts) if remark_opts else ''\n\n            all_entries.append({\n                'date': day,\n                'driver': DRIVER,\n                'type': '6.업무용(왕복)',\n                'from_class': '회사',\n                'from_name': COMPANY_NAME,\n                'from_addr': COMPANY_ADDR,\n                'to_class': '공항' if dest_name == '공항' else '거래처',\n                'to_name': dest_name,\n                'to_addr': dest_addr,\n                'km': km,\n                'remark': remark\n            })\n\n# Sort by date\nall_entries.sort(key=lambda x: x['date'])\n\n# Trim to ~376 if over\nif len(all_entries) > 380:\n    all_entries = all_entries[:376]\n\nprint(f\"Total entries: {len(all_entries)}\")\n\n# === Create Excel workbook (matching GV80 format exactly) ===\nwb = openpyxl.Workbook()\nws = wb.active\nws.title = \"차량 운행기록부\"\n\n# Styles\nheader_font = Font(bold=True, size=10, name='맑은 고딕')\ntitle_font = Font(bold=True, size=14, name='맑은 고딕')\nnormal_font = Font(size=10, name='맑은 고딕')\nthin_border = Border(\n    left=Side(style='thin'), right=Side(style='thin'),\n    top=Side(style='thin'), bottom=Side(style='thin')\n)\ncenter_align = Alignment(horizontal='center', vertical='center', wrap_text=True)\nleft_align = Alignment(horizontal='left', vertical='center', wrap_text=True)\nright_align = Alignment(horizontal='right', vertical='center')\nheader_fill = PatternFill(start_color='D9E1F2', end_color='D9E1F2', fill_type='solid')\nmonth_fill = PatternFill(start_color='E2EFDA', end_color='E2EFDA', fill_type='solid')\n\n# Column widths (A-M)\nwidths = [8, 14, 10, 10, 18, 10, 12, 30, 10, 14, 30, 10, 22]\nfor i, w in enumerate(widths):\n    ws.column_dimensions[get_column_letter(i+1)].width = w\n\n# Row 2: business registration\nws['A2'] = '사업자등록번호'\nws['A2'].font = header_font\nws['C2'] = 3128647372\nws['C2'].font = normal_font\nws['F2'] = '차량 운행기록부'\nws['F2'].font = title_font\n\n# Row 4\nws['A4'] = '1. 기본 정보 [ 신규차량 자동 등록시 - ①~⑤ 모두 기입/ 차량등록된경우-①~② 만 기입 ]'\nws['A4'].font = header_font\n\n# Row 5: field headers\nfield_headers = [('A', '①차종'), ('D', '②차량번호'), ('F', '③기초km'), ('H', '④취득일자'), ('I', '⑤사용사원'), ('K', '⑥임차여부')]\nfor col, val in field_headers:\n    cell = ws[f'{col}5']\n    cell.value = val\n    cell.font = header_font\n    cell.fill = header_fill\n    cell.border = thin_border\n    cell.alignment = center_align\n\n# Row 6: field values\nfield_values = [('A', 'G80'), ('D', 4963), ('I', '류대현'), ('K', '1.렌트')]\nfor col, val in field_values:\n    cell = ws[f'{col}6']\n    cell.value = val\n    cell.font = normal_font\n    cell.border = thin_border\n    cell.alignment = center_align\n\n# Row 8\nws['A8'] = '2. 차량 운행기록 내역'\nws['A8'].font = header_font\nws['M8'] = '[단위 : km]'\nws['M8'].font = normal_font\n\n# Row 9: column headers\ncol_headers = ['년도', '날짜', '부서', '성명', '구분', '분류(출)', '출발지명', '주소', '분류(도)', '도착지명', '주소', '주행km', '비    고']\nfor i, h in enumerate(col_headers):\n    cell = ws.cell(row=9, column=i+1, value=h)\n    cell.font = header_font\n    cell.border = thin_border\n    cell.fill = header_fill\n    cell.alignment = center_align\n\n# Data rows\nrow = 10\ncurrent_month = None\ntotal_km = 0\ndata_start_row = 10\n\nfor entry in all_entries:\n    d = entry['date']\n    m = d.month\n    y = d.year\n\n    # Month header (only for 2025 months)\n    month_key = (y, m)\n    if month_key != current_month and y == 2025:\n        current_month = month_key\n        cell = ws.cell(row=row, column=1, value=f'2025년 {m}월')\n        cell.font = Font(bold=True, size=10, name='맑은 고딕', color='006100')\n        for c in range(1, 14):\n            ws.cell(row=row, column=c).fill = month_fill\n            ws.cell(row=row, column=c).border = thin_border\n        row += 1\n\n    # Data row: A=년도, B=날짜, C=부서, D=성명, E=구분, F=분류(출), G=출발지명, H=주소, I=분류(도), J=도착지명, K=주소, L=주행km, M=비고\n    ws.cell(row=row, column=1, value=2025).font = normal_font\n    ws.cell(row=row, column=1).alignment = center_align\n    ws.cell(row=row, column=1).border = thin_border\n\n    # Date as datetime\n    from datetime import datetime\n    date_val = datetime(d.year, d.month, d.day)\n    cell_date = ws.cell(row=row, column=2, value=date_val)\n    cell_date.font = normal_font\n    cell_date.alignment = center_align\n    cell_date.border = thin_border\n    cell_date.number_format = 'YYYY-MM-DD'\n\n    # C=부서 (empty)\n    ws.cell(row=row, column=3).border = thin_border\n\n    # D=성명\n    ws.cell(row=row, column=4, value=entry['driver']).font = normal_font\n    ws.cell(row=row, column=4).alignment = center_align\n    ws.cell(row=row, column=4).border = thin_border\n\n    # E=구분\n    ws.cell(row=row, column=5, value=entry['type']).font = normal_font\n    ws.cell(row=row, column=5).alignment = center_align\n    ws.cell(row=row, column=5).border = thin_border\n\n    # F=분류(출)\n    ws.cell(row=row, column=6, value=entry['from_class']).font = normal_font\n    ws.cell(row=row, column=6).alignment = center_align\n    ws.cell(row=row, column=6).border = thin_border\n\n    # G=출발지명 (empty for commute/자택)\n    if entry['from_name']:\n        ws.cell(row=row, column=7, value=entry['from_name']).font = normal_font\n    ws.cell(row=row, column=7).alignment = left_align\n    ws.cell(row=row, column=7).border = thin_border\n\n    # H=주소\n    ws.cell(row=row, column=8, value=entry['from_addr']).font = normal_font\n    ws.cell(row=row, column=8).alignment = left_align\n    ws.cell(row=row, column=8).border = thin_border\n\n    # I=분류(도)\n    ws.cell(row=row, column=9, value=entry['to_class']).font = normal_font\n    ws.cell(row=row, column=9).alignment = center_align\n    ws.cell(row=row, column=9).border = thin_border\n\n    # J=도착지명\n    ws.cell(row=row, column=10, value=entry['to_name']).font = normal_font\n    ws.cell(row=row, column=10).alignment = left_align\n    ws.cell(row=row, column=10).border = thin_border\n\n    # K=주소\n    ws.cell(row=row, column=11, value=entry['to_addr']).font = normal_font\n    ws.cell(row=row, column=11).alignment = left_align\n    ws.cell(row=row, column=11).border = thin_border\n\n    # L=주행km\n    ws.cell(row=row, column=12, value=entry['km']).font = normal_font\n    ws.cell(row=row, column=12).alignment = right_align\n    ws.cell(row=row, column=12).border = thin_border\n\n    # M=비고\n    if entry['remark']:\n        ws.cell(row=row, column=13, value=entry['remark']).font = normal_font\n    ws.cell(row=row, column=13).alignment = left_align\n    ws.cell(row=row, column=13).border = thin_border\n\n    total_km += entry['km']\n    row += 1\n\n# Total row with SUM formula\nrow_total = row\nws.cell(row=row_total, column=1, value='합 계 : ').font = Font(bold=True, size=11, name='맑은 고딕')\nws.cell(row=row_total, column=1).border = thin_border\n# Use SUM formula like original\nws.cell(row=row_total, column=12, value=f'=SUM(L{data_start_row}:L{row_total-1})')\nws.cell(row=row_total, column=12).font = Font(bold=True, size=11, name='맑은 고딕')\nws.cell(row=row_total, column=12