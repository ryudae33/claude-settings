    \n    for idx, row in enumerate(rows, 1):\n        date, departure_loc, distance, dest, departure_time, driver, driver_addr, arrival_time, company, company_addr, total_km, remark = row\n        f.write(f\"Record {idx:3d}: {date} | {departure_loc:10s} | {distance:3s}km | {dest:20s} | {departure_time:5s} -> {arrival_time:5s} | {company:15s} | {remark}\\n\")\n    \n    f.write(\"\\n\" + \"=\" * 100 + \"\\n\")\n    f.write(\"2. 목적지 분석 (22가지 패턴)\\n\")\n    f.write(\"=\" * 100 + \"\\n\\n\")\n    for dest in sorted(destinations.keys(), key=lambda x: -len(destinations[x])):\n        count = len(destinations[dest])\n        f.write(f\"{dest:40s}: {count:3d}회 (기록 번호: {', '.join(map(str, destinations[dest][:10]))}{'...' if len(destinations[dest]) > 10 else ''})\\n\")\n    \n    f.write(\"\\n\" + \"=\" * 100 + \"\\n\")\n    f.write(\"3. 출발지 분석 (17가지 패턴)\\n\")\n    f.write(\"=\" * 100 + \"\\n\\n\")\n    for loc in sorted(locations.keys(), key=lambda x: -len(locations[x])):\n        count = len(locations[loc])\n        f.write(f\"{loc:20s}: {count:3d}회\\n\")\n    \n    f.write(\"\\n\" + \"=\" * 100 + \"\\n\")\n    f.write(\"4. 회사명 분석 (5가지)\\n\")\n    f.write(\"=\" * 100 + \"\\n\\n\")\n    for company in sorted(companies.keys(), key=lambda x: -len(companies[x])):\n        count = len(companies[company])\n        f.write(f\"{company:30s}: {count:3d}회\\n\")\n    \n    f.write(\"\\n\" + \"=\" * 100 + \"\\n\")\n    f.write(\"5. 비고(remarks) 분석 (5가지)\\n\")\n    f.write(\"=\" * 100 + \"\\n\\n\")\n    f.write(\"기록 없음 (공백): {}회\\n\".format(len(rows) - sum(len(v) for v in remarks.values())))\n    for remark in sorted(remarks.keys(), key=lambda x: -len(remarks[x])):\n        count = len(remarks[remark])\n        f.write(f\"{remark:40s}: {count:3d}회\\n\")\n    \n    f.write(\"\\n\" + \"=\" * 100 + \"\\n\")\n    f.write(\"6. 운전자 주소 분석\\n\")\n    f.write(\"=\" * 100 + \"\\n\\n\")\n    for addr in sorted(driver_addresses.keys(), key=lambda x: -len(driver_addresses[x])):\n        count = len(