*)\nbCmdHome    := %MW300.0;\nbCmdMove    := %MW300.1;\nbCmdJogCW   := %MW300.2;\nbCmdJogCCW  := %MW300.3;\nbCmdStop    := %MW300.4;\nbCmdReset   := %MW300.5;\nbCmdSetPos  := %MW300.6;\nbCmdServoOn := %MW300.7;\n\n(* 제어 부가 비트 (MW301) *)\nbMoveDir    := %MW301.0;\nbMoveRel    := %MW301.1;\n\n(* 2. 파라미터 읽기 (MW310~319, DINT = 2 WORD) *)\ndinTargetPos := WORD_TO_DINT(%MW310) + WORD_TO_DINT(%MW311) * 65536;\ndinTargetVel := WORD_TO_DINT(%MW312) + WORD_TO_DINT(%MW313) * 65536;\ndinJogVel    := WORD_TO_DINT(%MW314) + WORD_TO_DINT(%MW315) * 65536;\ndinAccel     := WORD_TO_DINT(%MW316) + WORD_TO_DINT(%MW317) * 65536;\ndinDecel     := WORD_TO_DINT(%MW318) + WORD_TO_DINT(%MW319) * 65536;\n\n(* 3. 엣지 트리거 검출 *)\ng_CMD_Home_RT(CLK := bCmdHome);\ng_CMD_Move_RT(CLK := bCmdMove);\ng_CMD_Stop_RT(CLK := bCmdStop);\ng_CMD_Reset_RT(CLK := bCmdReset);\ng_CMD_SetPos_RT(CLK := bCmdSetPos);\n\n(* 4. 명령 실행 플래그 세팅 *)\nIF g_CMD_Home_RT.Q THEN\n    g_bHomeExec := TRUE;\nEND_IF;\nIF g_FB_Home.Done OR g_FB_Home.Error THEN\n    g_bHomeExec := FALSE;\nEND_IF;\n\nIF g_CMD_Move_RT.Q THEN\n    g_bMoveExec := TRUE;\nEND_IF;\nIF g_FB_MoveAbs.Done OR g_FB_MoveAbs.Error THEN\n    g_bMoveExec := FALSE;\nEND_IF;\n\nIF g_CMD_Stop_RT.Q THEN\n    g_bStopExec := TRUE;\nEND_IF;\nIF g_FB_Stop.Done OR g_FB_Stop.Error THEN\n    g_bStopExec := FALSE;\nEND_IF;\n\nIF g_CMD_Reset_RT.Q THEN\n    g_bResetExec := TRUE;\nEND_IF;\nIF g_FB_Reset.Done OR g_FB_Reset.Error THEN\n    g_bResetExec := FALSE;\nEND_IF;\n\nIF g_CMD_SetPos_RT.Q THEN\n    g_bSetPosExec := TRUE;\nEND_IF;\nIF g_FB_SetPos.Done OR g_FB_SetPos.Error THEN\n    g_bSetPosExec := FALSE;\nEND_IF;\n\n(* 5. MC_xxx FB 호출 *)\ng_FB_Home(Axis := _MC_AX[0], Execute := g_bHomeExec);\n\ng_FB_MoveAbs(\n    Axis         := _MC_AX[0],\n    Execute      := g_bMoveExec,\n    Position     := DINT_TO_LREAL(dinTargetPos),\n    Velocity     := DINT_TO_LREAL(dinTargetVel),\n    Acceleration := DINT_TO_LREAL(dinAccel),\n    Deceleration := DINT_TO_LREAL(dinDecel),\n    Direction    := 0\n);\n\ng_FB_JogCW(\n    Axis        := _MC_AX[0],\n    JogForward  := bCmdJogCW,\n    JogBackward := FALSE,\n    Velocity    := DINT_TO_LREAL(dinJogVel),\n    Acceleration := DINT_TO_LREAL(dinAccel),\n    Deceleration := DINT_TO_LREAL(dinDecel)\n);\n\ng_FB_JogCCW(\n    Axis        := _MC_AX[0],\n    JogForward  := FALSE,\n    JogBackward := bCmdJogCCW,\n    Velocity    := DINT_TO_LREAL(dinJogVel),\n    Acceleration := DINT_TO_LREAL(dinAccel),\n    Deceleration := DINT_TO_LREAL(dinDecel)\n);\n\ng_FB_Stop(\n    Axis         := _MC_AX[0],\n    Execute      := g_bStopExec,\n    Deceleration := DINT_TO_LREAL(dinDecel)\n);\n\ng_FB_Reset(Axis := _MC_AX[0], Execute := g_bResetExec);\n\ng_FB_SetPos(\n    Axis     := _MC_AX[0],\n    Execute  := g_bSetPosExec,\n    Position := DINT_TO_LREAL(dinTargetPos)\n);\n\n(* 6. 서보 상태 비트 갱신 → MW400 *)\nwStatus := 0;\n\nIF _MC_AX[0].IsMoving THEN\n    wStatus := wStatus OR 16#0001;\nEND_IF;\nIF _MC_AX[0].Error THEN\n    wStatus := wStatus OR 16#0002;\nEND_IF;\nIF _MC_AX[0].InPosition THEN\n    wStatus := wStatus OR 16#0004;\nEND_IF;\nIF _MC_AX[0].InPosition AND (NOT _MC_AX[0].IsMoving) THEN\n    wStatus := wStatus OR 16#0008;\nEND_IF;\nIF _MC_AX[0].IsHomed THEN\n    wStatus := wStatus OR 16#0010;\nEND_IF;\nIF _MC_AX[0].IsHoming THEN\n    wStatus := wStatus OR 16#0020;\nEND_IF;\nIF bCmdServoOn AND _00_IN01 THEN\n    wStatus := wStatus OR 16#0040;\nEND_IF;\nIF bCmdServoOn AND _MC_AX[0].IsHomed AND (NOT _MC_AX[0].Error) THEN\n    wStatus := wStatus OR 16#0080;\nEND_IF;\n\n%MW400 := wStatus;\n\n(* 7. 명령 응답 비트 갱신 → MW401 *)\nwResponse := 0;\n\nIF g_FB_Home.Done THEN\n    wResponse := wResponse OR 16#0001;\nEND_IF;\nIF g_FB_MoveAbs.Done THEN\n    wResponse := wResponse OR 16#0002;\nEND_IF;\nIF g_FB_Home.Error THEN\n    wResponse := wResponse OR 16#0004;\nEND_IF;\nIF g_FB_MoveAbs.Error THEN\n    wResponse := wResponse OR 16#0008;\nEND_IF;\nIF g_FB_Reset.Done THEN\n    wResponse := wResponse OR 16#0010;\nEND_IF;\n\n%MW401 := wResponse;\n\n(* 8. 서보 상태값 갱신 → MW410~415 *)\n%MW410 := DINT_TO_WORD(LREAL_TO_DINT(_MC_AX[0].ActualPosition) MOD 65536);\n%MW411 := DINT_TO_WORD(LREAL_TO_DINT(_MC_AX[0].ActualPosition) / 65536);\n%MW412 := DINT_TO_WORD(LREAL_TO_DINT(_MC_AX[0].ActualVelocity) MOD 65536);\n%MW413 := DINT_TO_WORD(LREAL_TO_DINT(_MC_AX[0].ActualVelocity) / 65536);\n%MW414 := _MC_AX[0].ErrorID;\n%MW415 := LREAL_TO_WORD(_MC_AX[0].ActualPosition / 100.0);\n"},"sourceToolAssistantUUID":"f35fabf9-92f7-4155-a813-0408f5b3e766","userType":"external","cwd":"C:\\Users\\Administrator\\Desktop\\1cellAssembleMachine\\PLC_ST","sessionId":"e71c4942-247c-4f55-b290-1dd218ab6392","version":"2.1.77","gitBranch":"HEAD","slug":"cached-kindling-crystal"}
