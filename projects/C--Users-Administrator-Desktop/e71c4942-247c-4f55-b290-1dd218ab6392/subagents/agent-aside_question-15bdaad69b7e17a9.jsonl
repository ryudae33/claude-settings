1 OR 16#0001;\nEND_IF;\n\nIF g_EMO_Active THEN\n    %MW501 := %MW501 OR 16#0002;\nEND_IF;\n\nIF %MW400.1 THEN\n    %MW501 := %MW501 OR 16#0004;\nEND_IF;\n\nIF g_WD_Timeout THEN\n    %MW501 := %MW501 OR 16#0008;\nEND_IF;\n\n%MW501 := %MW501 OR 16#0010;\n\n(* 7. 스캔 카운터 *)\ng_ScanCount := g_ScanCount + 1;\n","structuredPatch":[{"oldStart":8,"oldLines":7,"newStart":8,"newLines":7,"lines":[" wHeartbeat := %MW500 AND 16#00FF;"," bPcReady := %MW500.8;"," bPcEmoReq := %MW500.9;","-bEmoInput := _00_IN11;","+bEmoInput := %IX0.0.11;"," "," (* 2. Watchdog 감시 — 500ms 무변화 시 통신 두절 *)"," IF wHeartbeat <> g_WD_PrevCount THEN"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"02f7679a-7395-4de4-b4bc-c595c3ad9b70","userType":"external","cwd":"C:\\Users\\Administrator\\Desktop\\1cellAssembleMachine\\PLC_ST","sessionId":"e71c4942-247c-4f55-b290-1dd218ab6392","version":"2.1.77","gitBranch":"HEAD","slug":"cached-kindling-crystal"}
