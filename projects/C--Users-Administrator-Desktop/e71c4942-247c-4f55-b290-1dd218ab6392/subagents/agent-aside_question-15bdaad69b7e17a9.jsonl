 %MW400.1 THEN\n    %MW501 := %MW501 OR 16#0004;\nEND_IF;\n\nIF g_WD_Timeout THEN\n    %MW501 := %MW501 OR 16#0008;\nEND_IF;\n\n%MW501 := %MW501 OR 16#0010;\n\n(* 7. 스캔 카운터 *)\ng_ScanCount := g_ScanCount + 1;\n","numLines":69,"startLine":1,"totalLines":69}},"sourceToolAssistantUUID":"f0962ba8-9681-4494-97a2-03e131050048","userType":"external","cwd":"C:\\Users\\Administrator\\Desktop\\1cellAssembleMachine\\PLC_ST","sessionId":"e71c4942-247c-4f55-b290-1dd218ab6392","version":"2.1.77","gitBranch":"HEAD","slug":"cached-kindling-crystal"}
