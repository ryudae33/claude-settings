Dim section As String = \"POS_\" & SpecNames(cboSpec.SelectedIndex)\n\n        ' 이미지 로드\n        Dim imgPath As String = iniFile.ReadValue(section, \"ImagePath\", \"\")\n        txtImagePath.Text = imgPath\n        SetImage(imgPath)\n\n        ' 좌표 로드\n        For i As Integer = 0 To 4\n            txtX(i).Text = iniFile.ReadValue(section, \"P\" & (i + 1) & \"X\", \"0\")\n            txtY(i).Text = iniFile.ReadValue(section, \"P\" & (i + 1) & \"Y\", \"0\")\n        Next\n\n        ' 원 크기\n        txtCircleSize.Text = iniFile.ReadValue(section, \"CircleSize\", \"30\")\n\n        picPreview.Invalidate()\n    End Sub\n\n    Private Sub SetImage(imgPath As String)\n        If currentImage IsNot Nothing Then\n            currentImage.Dispose()\n            currentImage = Nothing\n        End If\n        If System.IO.File.Exists(imgPath) Then\n            currentImage = Image.FromFile(imgPath)\n        End If\n    End Sub\n\n    Private Sub btnSelectImage_Click(sender As Object, e As EventArgs) Handles btnSelectImage.Click\n        Using dlg As New OpenFileDialog()\n            dlg.Filter = \"이미지 파일|*.bmp;*.jpg;*.jpeg;*.png;*.gif|모든 파일|*.*\"\n            dlg.Title = \"이미지 파일 선택\"\n            If dlg.ShowDialog() = DialogResult.OK Then\n                txtImagePath.Text = dlg.FileName\n                SetImage(dlg.FileName)\n                picPreview.Invalidate()\n            End If\n        End Using\n    End Sub\n\n    ' 이미지 클릭 → 선택된 P 좌표 설정 후 다음 P로 이동\n    Private Sub picPreview_MouseClick(sender As Object, e As MouseEventArgs) Handles picPreview.MouseClick\n        If currentImage Is Nothing Then Return\n\n        ' picPreview 화면 좌표 → 이미지 원본 좌표 변환\n        Dim imgX As Integer = CInt(e.X * currentImage.Width / picPreview.Width)\n        Dim imgY As Integer = CInt(e.Y * currentImage.Height / picPreview.Height)\n\n        For i As Integer = 0 To 4\n            If rdoP(i).Checked Then\n                txtX(i).Text = imgX.ToString()\n                txtY(i).Text = imgY.ToString()\n                ' 다음 P로 자동 이동\n                If i < 4 Then rdoP(i + 1).Checked = True\n                Exit For\n            End If\n        Next\n\n        picPreview.Invalidate()\n    End Sub\n\n    Private Sub picPreview_Paint(sender As Object, e As PaintEventArgs) Handles picPreview.Paint\n        Dim g As Graphics = e.Graphics\n\n        ' 이미지 그리기 (StretchImage)\n        If currentImage IsNot Nothing Then\n            g.DrawImage(currentImage, picPreview.ClientRectangle)\n        End If\n\n        ' 원 크기 / 글자 크기 (비율 자동 추종)\n        Dim circleSize As Integer = 30\n        Integer.TryParse(txtCircleSize.Text, circleSize)\n        If circleSize < 10 Then circleSize = 10\n        Dim fontSize As Single = Math.Max(6, circleSize * 0.4F)\n\n        ' 이미지 원본 → 화면 스케일\n        Dim scaleX As Single = 1.0F\n        Dim scaleY As Single = 1.0F\n        If currentImage IsNot Nothing Then\n            scaleX = CSng(picPreview.Width) / currentImage.Width\n            scaleY = CSng(picPreview.Height) / currentImage.Height\n        End If\n\n        Using brushBlack As New SolidBrush(Color.Black)\n        Using brushWhite As New SolidBrush(Color.White)\n        Using penWhite As New Pen(Color.White, 1)\n        Using fnt As New Font(\"Arial\", fontSize, FontStyle.Bold)\n            For i As Integer = 0 To 4\n                Dim px As Integer = 0\n                Dim py As Integer = 0\n                Integer.TryParse(txtX(i).Text, px)\n                Integer.TryParse(txtY(i).Text, py)\n\n                Dim sx As Integer = CInt(px * scaleX)\n                Dim sy As Integer = CInt(py * scaleY)\n\n                Dim rect As New Rectangle(sx - circleSize \\ 2, sy - circleSize \\ 2, circleSize, circleSize)\n                g.FillEllipse(brushBlack, rect)\n                g.DrawEllipse(penWhite, rect)\n\n                Dim numStr As String = CStr(i + 1)\n                Dim strSize As SizeF = g.MeasureString(numStr, fnt)\n                g.DrawString(numStr, fnt, brushWhite,\n                    sx - strSize.Width / 2,\n                    sy - strSize.Height / 2)\n            Next\n        End Using\n        End Using\n        End Using\n        End Using\n    End Sub\n\n    Private Sub btnSave_Click(sender As Object, e As EventArgs) Handles btnSave.Click\n        Dim iniFile As New IniFile(iniFilePath)\n        Dim section As String = \"POS_\" & SpecNames(cboSpec.SelectedIndex)\n\n        iniFile.WriteValue(section, \"ImagePath\", txtImagePath.Text)\n        For i As Integer = 0 To 4\n            iniFile.WriteValue(section, \"P\" & (i + 1) & \"X\", txtX(i).Text)\n            iniFile.WriteValue(section, \"P\" & (i + 1) & \"Y\", txtY(i).Text)\n        Next\n        iniFile.WriteValue(section, \"CircleSize\", txtCircleSize.Text)\n\n        MessageBox.Show(\"저장 완료\", \"알림\", MessageBoxButtons.OK, MessageBoxIcon.Information)\n    End Sub\n\n    Private Sub btnClose_Click(sender As Object, e As EventArgs) Handles btnClose.Click\n        If currentImage IsNot Nothing Then currentImage.Dispose()\n        Me.Close()\n    End Sub\n\n    ' 좌표/원크기 변경 시 미리보기 실시간 갱신\n    Private Sub txtCoord_TextChanged(sender As Object, e As EventArgs) _\n        Handles txtP1X.TextChanged, txtP1Y.TextChanged,\n                txtP2X.TextChanged, txtP2Y.TextChanged,\n                txtP3X.TextChanged, txtP3Y.TextChanged,\n                txtP4X.TextChanged, txtP4Y.TextChanged,\n                txtP5X.TextChanged, txtP5Y.TextChanged,\n                txtCircleSize.TextChanged\n        picPreview.Invalidate()\n    End Sub\n\nEnd Class\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"2a93079c-ba73-4e66-b3d6-924395747ead"}
