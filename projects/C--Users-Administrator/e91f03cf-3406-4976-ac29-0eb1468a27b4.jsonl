ivate Sub DingDOng()\n\n        Me.Player.SoundLocation = System.AppDomain.CurrentDomain.BaseDirectory & \"\\SOUND\\DINGDONG.wav\"\n        Me.Player.Play()\n\n    End Sub\n\n    Private Sub NG()\n\n        Me.Player.SoundLocation = System.AppDomain.CurrentDomain.BaseDirectory & \"\\SOUND\\NG.wav\"\n        Me.Player.Play()\n\n    End Sub\n\n    Private Sub LabelNameing()\n\n        IN_LABEL(0) = LABEL_ADDRESS_IN_0\n        IN_LABEL(1) = LABEL_ADDRESS_IN_1\n        IN_LABEL(2) = LABEL_ADDRESS_IN_2\n\n        OUT_LABEL(0) = LABEL_ADDRESS_OUT_0\n        OUT_LABEL(1) = LABEL_ADDRESS_OUT_1\n        OUT_LABEL(2) = LABEL_ADDRESS_OUT_2\n        OUT_LABEL(3) = LABEL_ADDRESS_OUT_3\n        OUT_LABEL(4) = LABEL_ADDRESS_OUT_4\n        OUT_LABEL(5) = LABEL_ADDRESS_OUT_5\n\n        VALUE_IN_LABEL(0) = VALUE_ADDRESS_IN_0\n        VALUE_IN_LABEL(1) = VALUE_ADDRESS_IN_1\n        VALUE_IN_LABEL(2) = VALUE_ADDRESS_IN_2\n\n        VALUE_OUT_LABEL(0) = VALUE_ADDRESS_OUT_0\n        VALUE_OUT_LABEL(1) = VALUE_ADDRESS_OUT_1\n        VALUE_OUT_LABEL(2) = VALUE_ADDRESS_OUT_2\n        VALUE_OUT_LABEL(3) = VALUE_ADDRESS_OUT_3\n        VALUE_OUT_LABEL(4) = VALUE_ADDRESS_OUT_4\n        VALUE_OUT_LABEL(5) = VALUE_ADDRESS_OUT_5\n\n        'IN_LABEL(0).Text = \"W0000\"\n        'IN_LABEL(1).Text = \"W0001\"\n\n        'OUT_LABEL(0).Text = \"W0050\"\n        'OUT_LABEL(1).Text = \"W0051\"\n        'OUT_LABEL(2).Text = \"W0052\"\n        'OUT_LABEL(3).Text = \"W0053\"\n        'OUT_LABEL(4).Text = \"W0054\"\n        'OUT_LABEL(5).Text = \"W0055\"\n\n        IN_LABEL(0).Text = \"W\" & Format(PlcInStartAddress, \"0000\")\n        IN_LABEL(1).Text = \"W\" & Format(PlcInStartAddress + 1, \"0000\")\n        IN_LABEL(2).Text = \"W\" & Format(PlcInStartAddress + 2, \"0000\")\n\n        OUT_LABEL(0).Text = \"W\" & Format(PlcOutStartAddress, \"0000\")\n        OUT_LABEL(1).Text = \"W\" & Format(PlcOutStartAddress + 1, \"0000\")\n        OUT_LABEL(2).Text = \"W\" & Format(PlcOutStartAddress + 2, \"0000\")\n        OUT_LABEL(3).Text = \"W\" & Format(PlcOutStartAddress + 3, \"0000\")\n        OUT_LABEL(4).Text = \"W\" & Format(PlcOutStartAddress + 4, \"0000\")\n        OUT_LABEL(5).Text = \"W\" & Format(PlcOutStartAddress + 5, \"0000\")\n\n    End Sub\n\n\n    Private Sub Button4_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles Button4.Click\n\n    End Sub\n\n    Private Sub Button3_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles Button3.Click\n        FrmPort.Show()\n    End Sub\n\n    Private Sub Button1_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles Button1.Click\n        End\n    End Sub\n\n    Private Sub LoadPicture(ByVal picTarget As PictureBox, ByVal picName As String)\n\n        Try\n            picTarget.Image = System.Drawing.Image.FromFile(System.AppDomain.CurrentDomain.BaseDirectory & \"\\Image\\\" & picName & \".png\")\n        Catch ex As Exception\n        End Try\n\n        'LoadPicture(Picture_Main, \"ASSEMBLE\\NHGT\")\n\n    End Sub\n\n    Private Sub InitControl()\n\n        aStep = 0\n        RealAirToolCount = 0\n\n        REWORK_STOP = False\n        Panel_Pump_VAlue.Text = \"\"\n        Panel_Pump_DEC.BackColor = Color.White\n        Panel_Pump_DEC.Text = \"\"\n        TargetBlower.Text = \"\"\n        Panel_Blower_Value.Text = \"\"\n        Panel_Blower_DEC.Text = \"\"\n        Panel_Blower_DEC.BackColor = Color.White\n        Panel_Total_DEC.Text = \"\"\n        Panel_Total_DEC.BackColor = Color.White\n\n        Panel_PartName.Text = \"\"\n        Panel_Before.Text = \"\"\n        Panel_PartNo.Text = \"\"\n        Panel_CarType.Text = \"\"\n        Panel_Position.Text = \"\"\n        Panel_HGT.Text = \"\"\n        Panel_SN.Text = \"\"\n        Panel_Vent.Text = \"\"\n        Panel_Warmer.Text = \"\"\n        Panel_Undertray.Text = \"\"\n        Panel_Can.Text = \"\"\n        Panel_Rework.Text = \"\"\n        Panel_Now.Text = \"\"\n\n        Panel_RF_READ.Text = \"\"\n        Panel_RF_DataCHeck.Text = \"\"\n        Panel_RF_DataCHeck.BackColor = Color.White\n\n        For i As Integer = 1 To 8\n            SHAPE_W(i) = 0\n            SHAPE_H(i) = 0\n        Next\n\n        Panel_TQ1.Text = \"\"\n        Panel_TQ2.Text = \"\"\n        Panel_TQ3.Text = \"\"\n        Panel_TQ4.Text = \"\"\n        Panel_TQ5.Text = \"\"\n\n        Panel_TQ1_DEC.Text = \"\"\n        Panel_TQ2_DEC.Text = \"\"\n        Panel_TQ3_DEC.Text = \"\"\n        Panel_TQ4_DEC.Text = \"\"\n        Panel_TQ5_DEC.Text = \"\"\n\n        Panel_TQ1_DEC.BackColor = Color.White\n        Panel_TQ2_DEC.BackColor = Color.White\n        Panel_TQ3_DEC.BackColor = Color.White\n        Panel_TQ4_DEC.BackColor = Color.White\n        Panel_TQ5_DEC.BackColor = Color.White\n\n        pos1.Text = \"\"\n        pos2.Text = \"\"\n        pos3.Text = \"\"\n        pos4.Text = \"\"\n        pos5.Text = \"\"\n        toolstep = 0\n\n        Panel_Before.BackColor = Color.White\n        Panel_Before.ForeColor = Color.White\n\n        Panel_Rework.BackColor = Color.White\n        Panel_Rework.ForeColor = Color.White\n\n        Panel_Now.BackColor = Color.White\n        Panel_Now.ForeColor = Color.White\n\n        LoadPicture(Picture_Main, \"NON\")\n\n    End Sub\n\n    Private Sub Read_RFiD()\n\n        If Serial_RFID.IsOpen = True Then\n\n            'RFID Data length => 1A(26자리) 읽어오기 *앞 3자리 파레트 넘버 나머지 23자리 시리얼 넘버\n            Serial_RFID.Write(Chr(\"&H02\") & Chr(\"&H02\") & Chr(\"&H00\") & Chr(\"&H07\") & Chr(\"&H05\") & Chr(\"&H00\") & Chr(\"&H00\") &\n                                          Chr(\"&H00\") & Chr(\"&H1A\") & Chr(\"&H03\") & Chr(\"&HE8\") & Chr(\"&H03\"))\n        End If\n\n    End Sub\n\n    Private Sub Write_RFID(ByVal str As String)\n\n        Dim i As Integer\n\n        Dim tmp1 As String = Chr(\"&H02\") & Chr(\"&H02\") & Chr(\"&H00\") & Chr(\"&H1E\") & Chr(\"&H06\") & Chr(\"&H00\") & Chr(\"&H00\") &\n                                                Chr(\"&H00\") & Chr(\"&H17\") & Chr(\"&H03\") & Chr(\"&HE8\")\n\n        tmp1 = tmp1 & str & Chr(\"&H03\")\n\n        If Serial_RFID.IsOpen = True Then\n            Serial_RFID.Write(tmp1)\n        End If\n\n    End Sub\n\n    Private Sub ThreadTask1()\n\n        Dim i As Integer\n        Dim sRecvData As String = \"\"\n        Dim RFID_Tag_Data As String = \"\"\n\n        Do\n            Dim Incoming1 As String = Serial_RFID.ReadByte\n            If Incoming1 Is Nothing Then\n            Else\n                sRecvData = sRecvData & Chr(Incoming1)\n                If Incoming1 = 3 Then 'ETX\n                    If sRecvData.Length = 7 Or sRecvData.Length = 6 Then\n                        Panel_RF_READ.Text = \"Empty\"\n                    Else\n                        RFID_Tag_Data = Mid(sRecvData, 6, 26)\n                        Label11.Text = RFID_Tag_Data\n                        Panel_RF_READ.Text = Mid(RFID_Tag_Data, 4, 23)\n                        RFID_Pallet_No = Mid(RFID_Tag_Data, 1, 3)\n                        'Panel_Pallet.Text = RFID_Pallet_No\n                    End If\n                    'For i = 1 To sRecvData.Length\n                    'TextBox1.Text = TextBox1.Text & Mid(sRecvData, i, 1) & \" \"\n                    'Next\n                    'TextBox1.Text = TextBox1.Text & vbCrLf\n                    sRecvData = \"\"\n                End If\n            End If\n        Loop\n\n    End Sub\n\n\n    Sub SerialOpen()\n\n        Try\n            If Serial_RFID.IsOpen() = True Then\n                Serial_RFID.Close()\n            End If\n            Serial_RFID.PortName = PortNumber_Rfid\n            Serial_RFID.ReceivedBytesThreshold = 50\n            Serial_RFID.BaudRate = 9600\n            Serial_RFID.DataBits = 8\n            Serial_RFID.Open()\n        Catch ex As Exception\n            MsgBox(\"Serial Open RFID Fail \" & PortNumber_Rfid)\n        End Try\n\n        If PortNumber_Scanner = \"NONE\" Then\n        Else\n            Try\n                If Serial_Scanner.IsOpen() = True Then\n                    Serial_Scanner.Close()\n                End If\n                Serial_Scanner.PortName = PortNumber_Scanner\n                Serial_Scanner.BaudRate = 9600\n                Serial_Scanner.DataBits = 8\n                Serial_Scanner.Open()\n            Catch ex As Exception\n\n                MsgBox(\"Serial Open Scanner Fail \" & PortNumber_Scanner)\n            End Try\n        End If\n\n        If PortNumber_Tool1 = \"NONE\" Then\n\n        Else\n            Try\n                Serial_Tool1.PortName = PortNumber_Tool1\n                If Serial_Tool1.IsOpen() = True Then\n                    Serial_Tool1.Close()\n                    Serial_Tool1.DataBits = 8\n                    Serial_Tool1.Open()\n                Else\n                    Serial_Tool1.BaudRate = 9600\n                    Serial_Tool1.DataBits = 8\n                    Serial_Tool1.Open()\n                End If\n                Serial_Tool1.Write(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200001            \" & Chr(\"0\") & Chr(\"3\"))\n                Serial_Tool1.Write(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200060            \" & Chr(\"0\") & Chr(\"3\"))\n                Tmr_TOOL1.Interval = 5000\n                Tmr_TOOL1.Start()\n            Catch ex As Exception\n                MsgBox(\"Serial Open Tool Fail \" & PortNumber_Tool1)\n            End Try\n        End If\n\n        If PortNumber_Tool2 = \"NONE\" Then\n\n        Else\n            Try\n\n            Catch ex As Exception\n                Serial_Tool2.PortName = PortNumber_Tool2\n                If Serial_Tool2.IsOpen() = True Then\n                    Serial_Tool2.Close()\n                    Serial_Tool2.DataBits = 8\n                    Serial_Tool2.Open()\n                Else\n                    Serial_Tool2.BaudRate = 9600\n                    Serial_Tool2.DataBits = 8\n                    Serial_Tool2.Open()\n                End If\n                Serial_Tool2.Write(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200001            \" & Chr(\"0\") & Chr(\"3\"))\n                Serial_Tool2.Write(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200060            \" & Chr(\"0\") & Chr(\"3\"))\n                Tmr_TOOL2.Interval = 5000\n                Tmr_TOOL2.Start()\n            End Try\n        End If\n        If PortNumber_Module = \"NONE\" Then\n        Else\n            Try\n\n                If Serial_Module.IsOpen() = True Then\n                    Serial_Module.Close()\n                    Serial_Module.PortName = PortNumber_Module\n                    Serial_Module.BaudRate = 115200\n                    Serial_Module.DataBits = 8\n                    Serial_Module.Open()\n                    'Label8.Text = \"Module OK\"\n                Else\n                    Serial_Module.PortName = PortNumber_Module\n                    Serial_Module.BaudRate = 115200\n                    Serial_Module.DataBits = 8\n                    Serial_Module.Open()\n                    'Label8.Text = \"Module OK\"\n                End If\n\n            Catch ex As Exception\n\n                MsgBox(\"Serial Open Module Fail \" & PortNumber_Module)\n\n            End Try\n        End If\n\n\n    End Sub\n\n    Private Sub ThreadTask2()\n\n        Dim Incoming1 As String\n\n        Do While Serial_Tool1.IsOpen = True\n\n            Try\n\n                If Serial_Tool1.BytesToRead > 0 Then\n\n                    Incoming1 = Serial_Tool1.ReadChar\n\n                    If Incoming1 = 3 Then\n\n                        If Len(Tool_String1) = 59 And Mid(Tool_String1, 6, 4) = \"0002\" Then\n                            Serial_Tool1.WriteLine(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200060            \" & Chr(\"0\") & Chr(\"3\"))\n                        ElseIf Len(Tool_String1) = 26 And Mid(Tool_String1, 6, 4) = \"0005\" Then\n                            Serial_Tool1.WriteLine(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00209999            \" & Chr(\"0\") & Chr(\"3\"))\n                        ElseIf Len(Tool_String1) = 22 And Mid(Tool_String1, 6, 4) = \"9999\" Then\n                            Tool_Connection1 = True\n                        ElseIf Len(Tool_String1) > 200 And Mid(Tool_String1, 6, 4) = \"0061\" Then\n\n                            Serial_Tool1.WriteLine(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200062            \" & Chr(\"0\") & Chr(\"3\"))\n\n                            ' N/HGT toolstep 10~14 (CurrentToolP 사용)\n                            If toolstep = 10 Then\n                                If CheckIOCondition(CurrentToolP(0)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ1.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ1_DEC.Text = \"OK\"\n                                        Panel_TQ1_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 11\n                                    End If\n                                Else\n                                    Panel_TQ1_DEC.Text = \"POS NG\"\n                                    Panel_TQ1_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            ElseIf toolstep = 11 Then\n                                If CheckIOCondition(CurrentToolP(1)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ2.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ2_DEC.Text = \"OK\"\n                                        Panel_TQ2_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 12\n                                    End If\n                                Else\n                                    Panel_TQ2_DEC.Text = \"POS NG\"\n                                    Panel_TQ2_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            ElseIf toolstep = 12 Then\n                                If CheckIOCondition(CurrentToolP(2)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ3.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ3_DEC.Text = \"OK\"\n                                        Panel_TQ3_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 13\n                                    End If\n                                Else\n                                    Panel_TQ3_DEC.Text = \"POS NG\"\n                                    Panel_TQ3_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            ElseIf toolstep = 13 Then\n                                If CheckIOCondition(CurrentToolP(3)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ4.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ4_DEC.Text = \"OK\"\n                                        Panel_TQ4_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 14\n                                    End If\n                                Else\n                                    Panel_TQ4_DEC.Text = \"POS NG\"\n                                    Panel_TQ4_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            ElseIf toolstep = 14 Then\n                                If CheckIOCondition(CurrentToolP(4)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ5.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ5_DEC.Text = \"OK\"\n                                        Panel_TQ5_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 1000\n                                    End If\n                                Else\n                                    Panel_TQ5_DEC.Text = \"POS NG\"\n                                    Panel_TQ5_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                                ' HGT toolstep 100~104 (CurrentToolP 사용)\n                            ElseIf toolstep = 100 Then\n                                If CheckIOCondition(CurrentToolP(0)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ1.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ1_DEC.Text = \"OK\"\n                                        Panel_TQ1_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 101\n                                    End If\n                                Else\n                                    Panel_TQ1_DEC.Text = \"POS NG\"\n                                    Panel_TQ1_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            ElseIf toolstep = 101 Then\n                                If CheckIOCondition(CurrentToolP(1)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ2.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ2_DEC.Text = \"OK\"\n                                        Panel_TQ2_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 102\n                                    End If\n                                Else\n                                    Panel_TQ2_DEC.Text = \"POS NG\"\n                                    Panel_TQ2_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            ElseIf toolstep = 102 Then\n                                If CheckIOCondition(CurrentToolP(2)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ3.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ3_DEC.Text = \"OK\"\n                                        Panel_TQ3_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 103\n                                    End If\n                                Else\n                                    Panel_TQ3_DEC.Text = \"POS NG\"\n                                    Panel_TQ3_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            ElseIf toolstep = 103 Then\n                                If CheckIOCondition(CurrentToolP(3)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ4.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ4_DEC.Text = \"OK\"\n                                        Panel_TQ4_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 104\n                                    End If\n                                Else\n                                    Panel_TQ4_DEC.Text = \"POS NG\"\n                                    Panel_TQ4_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            ElseIf toolstep = 104 Then\n                                If CheckIOCondition(CurrentToolP(4)) Then\n                                    If Mid(Tool_String1, 109, 1) = \"1\" Then\n                                        Panel_TQ5.Text = Format(Val(Mid(Tool_String1, 143, 3) & \".\" & Mid(Tool_String1, 146, 2)))\n                                        Panel_TQ5_DEC.Text = \"OK\"\n                                        Panel_TQ5_DEC.BackColor = Color.Blue\n                                        DingDOng()\n                                        toolstep = 1000\n                                    End If\n                                Else\n                                    Panel_TQ5_DEC.Text = \"POS NG\"\n                                    Panel_TQ5_DEC.BackColor = Color.Red\n                                    NG()\n                                End If\n\n                            End If\n\n                        End If\n\n                        Tool_String1 = \"\"\n                        Serial_Tool1.DiscardInBuffer()\n\n                    Else\n\n                        Tool_String1 = Tool_String1 & Chr(Incoming1)\n\n                    End If\n\n                End If\n\n            Catch ex As Exception\n\n            End Try\n\n            Application.DoEvents()\n\n        Loop\n\n    End Sub\n\n    Private Sub Tmr_TOOL1_Tick(ByVal sender As Object, ByVal e As EventArgs) Handles Tmr_TOOL1.Tick\n\n        If Tool1Connection = False Then\n            Tool1Connection = True\n            Serial_Tool1.Write(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"002099990010\" & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(\"0\") & Chr(\"3\"))\n        ElseIf Tool1Connection = True Then\n            Serial_Tool1.Write(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200001            \" & Chr(\"0\") & Chr(\"3\") & Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200060            \" & Chr(\"0\") & Chr(\"3\"))\n        End If\n\n    End Sub\n\n    Private Sub Tmr_TOOL2_Tick(ByVal sender As Object, ByVal e As EventArgs) Handles Tmr_TOOL2.Tick\n\n        If Tool2Connection = False Then\n            Tool2Connection = True\n            Serial_Tool2.Write(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"002099990010\" & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(20) & Chr(\"0\") & Chr(\"3\"))\n        ElseIf Tool2Connection = True Then\n            Serial_Tool2.Write(Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200001            \" & Chr(\"0\") & Chr(\"3\") &\n            Chr(\"7\") & Chr(\"9\") & Chr(\"7\") & Chr(\"9\") & Chr(\"2\") & \"00200060            \" & Chr(\"0\") & Chr(\"3\"))\n        End If\n\n    End Sub\n    Sub DO_ON(ByVal num1 As Integer)\n\n        Mid$(D_OutString, CInt(num1 + 2), 1) = \"1\"\n        LED_OUT(num1).Image = My.Resources.ResourceManager.GetObject(CStr(num1) & \" Filled-50\")\n\n    End Sub\n\n    Sub DO_OFF(ByVal num1 As Integer)\n\n        Mid$(D_OutString, CInt(num1 + 2), 1) = \"0\"\n        LED_OUT(num1).Image = My.Resources.ResourceManager.GetObject(CStr(num1) & \"-50\")\n\n    End Sub\n\n    Sub DO_WRITE()\n        If Serial_Module.IsOpen = True Then Serial_Module.Write(D_OutString)\n    End Sub\n    Private Sub Serial_Scanner_DataReceived(ByVal sender As Object, ByVal e As System.IO.Ports.SerialDataReceivedEventArgs) Handles Serial_Scanner.DataReceived\n\n        Dim Incoming As String\n        Incoming = Serial_Scanner.ReadLine()\n        Dim ScanDAta As String = Mid$(Incoming, 1, Len(Incoming) - 1)\n        Panel_Scanner_Input.Text = Mid$(Incoming, 1, Len(Incoming) - 1)\n\n        '        첫자리 LH, RH\n        '2~3자리 : 생산년도\n        '4자리 : 생산월(A - 1월, B - 2월 .....)\n        '5~6자리 : 생산일자\n        '7~11자리 : 로트숫자\n        '이후자리:   펌핑 작동력\n\n        If wStep > 5 Then\n\n            If (ScanDAta.Contains(\"LS\") = True Or ScanDAta.Contains(\"RS\") = True) And Panel_Pump_DEC.Text <> \"NA\" Then\n\n                Panel_Pump_VAlue.Text = Panel_Scanner_Input.Text\n                If CheckPumpDuplicated(Panel_Pump_VAlue.Text) = False Then\n                    If Panel_Position.Text = \"LH\" Then\n                        If Mid(Panel_Pump_VAlue.Text, 1, 2) = \"LS\" Then\n                            Panel_Pump_DEC.Text = \"OK\"\n                            Panel_Pump_DEC.BackColor = Color.Blue\n                            DingDOng()\n                        Else\n                            Panel_Pump_DEC.Text = \"NG\"\n                            Panel_Pump_DEC.BackColor = Color.Red\n                            NG()\n                        End If\n                    ElseIf Panel_Position.Text = \"RH\" Then\n                        If Mid(Panel_Pump_VAlue.Text, 1, 2) = \"RS\" Then\n                            Panel_Pump_DEC.Text = \"OK\"\n                            Panel_Pump_DEC.BackColor = Color.Blue\n                            DingDOng()\n                        Else\n                            Panel_Pump_DEC.Text = \"NG\"\n                            Panel_Pump_DEC.BackColor = Color.Red\n                            NG()\n                        End If\n                    End If\n                Else\n                    Panel_Pump_DEC.Text = \"DUPLICATED\"\n                    Panel_Pump_DEC.BackColor = Color.Red\n                    NG()\n                End If\n\n            Else\n\n                If Panel_Blower_DEC.Text <> \"NA\" Then\n                    Panel_Blower_Value.Text = Panel_Scanner_Input.Text\n                    If Panel_Scanner_Input.Text.Contains(OPTION_BLOWER_BARCODE) And Panel_Blower_DEC.Text <> \"NA\" Then\n                        Panel_Blower_Value.Text = Panel_Scanner_Input.Text\n                        If CheckBlowerDuplicated(Panel_Scanner_Input.Text) = True Then\n                            Panel_Blower_DEC.Text = \"Duplicated\"\n                            Panel_Blower_DEC.BackColor = Color.Red\n                            NG()\n                            wStep = 9\n                        Else\n                            Panel_Blower_Value.Text = Panel_Scanner_Input.Text\n                            Panel_Blower_DEC.Text = \"OK\"\n                            Panel_Blower_DEC.BackColor = Color.Blue\n                            DingDOng()\n                        End If\n                    Else\n                        Panel_Blower_Value.Text = Panel_Scanner_Input.Text\n                        Panel_Blower_DEC.Text = \"NG\"\n                        Panel_Blower_DEC.BackColor = Color.Red\n                        NG()\n                    End If\n\n                End If\n\n            End If\n\n        End If\n\n    End Sub\n\n    Private Sub Tmr_Connect_Tick(ByVal sender As Object, ByVal e As EventArgs) Handles Tmr_Connect.Tick\n\n        If tError1 = \"OK\" Then\n            PLC1_ERR.Text = tError1\n            PLC1_ERR.BackColor = Color.Blue\n            PLC1_ERR.ForeColor = Color.White\n        Else\n            PLC1_ERR.Text = tError1\n            PLC1_ERR.BackColor = Color.Red\n            PLC1_ERR.ForeColor = Color.White\n        End If\n\n        If tStep1 = 0 Then\n            PlcConnect()\n            tStep1 = 2\n        ElseIf tStep1 = 2 Then\n            If Flag_Connection_PLC1 = True Then\n                tStep1 = 3\n            Else\n                tStep1 = 0\n            End If\n        ElseIf tStep1 = 3 Then\n            tError1 = \"\"\n            PlcRead()\n            tStep1 = 4\n        ElseIf tStep1 = 4 Then\n            If tError1 <> \"\" Then\n                If tError1 = \"OK\" Then\n                    tStep1 = 2\n                Else\n                    ACT_PLC1.Close()\n                    tStep1 = 0\n                End If\n            End If\n        End If\n\n        RF_READ_COUNT = RF_READ_COUNT + 0.5\n        If RF_READ_COUNT >= 1 Then\n            Read_RFiD()\n            Label_Time.Text = Format(Now, \"yyyy-MM-dd HH:mm:ss\")\n            RF_READ_COUNT = 0\n        End If\n\n    End Sub\n\n    Private Sub PlcRead()\n\n        Dim iReturnCode As Integer              'Return code\n        Dim szDeviceName As String = \"\"         'List data for 'DeviceName'\n        Dim iNumberOfDeviceName As Integer = 0  'Data for 'DeviceSize'\n        Dim sharrDeviceValue() As Short         'Data for 'DeviceValue'\n        Dim szarrData() As String               'Array for 'Data'\n        Dim iNumber As Integer                  'Loop counter\n        Dim Arrysize As Integer = 11\n        Dim j As Integer\n        Dim i As Integer\n\n        ReDim sharrDeviceValue(Arrysize - 1)\n        ReDim szarrData(Arrysize - 1)\n\n        'szDeviceName = \"W0000\" & vbLf &\n        '                        \"W0001\" & vbLf &\n        '                        \"W0050\" & vbLf &\n        '                        \"W0051\" & vbLf &\n        '                        \"W0052\" & vbLf &\n        '                        \"W0053\" & vbLf &\n        '                        \"W0054\" & vbLf &\n        '                        \"W0055\" & vbLf &\n        '                        \"W0056\" & vbLf &\n        '                        \"W0057\"\n\n        szDeviceName = \"W\" & Format(PlcInStartAddress, \"0000\") & vbLf &\n                                \"W\" & Format(PlcInStartAddress + 1, \"0000\") & vbLf &\n                                \"W\" & Format(PlcInStartAddress + 2, \"0000\") & vbLf &\n                                \"W\" & Format(PlcOutStartAddress, \"0000\") & vbLf &\n                                \"W\" & Format(PlcOutStartAddress + 1, \"0000\") & vbLf &\n                                \"W\" & Format(PlcOutStartAddress + 2, \"0000\") & vbLf &\n                                \"W\" & Format(PlcOutStartAddress + 3, \"0000\") & vbLf &\n                                \"W\" & Format(PlcOutStartAddress + 4, \"0000\") & vbLf &\n                                \"W\" & Format(PlcOutStartAddress + 5, \"0000\") & vbLf &\n                                \"W\" & Format(PlcOutStartAddress + 6, \"0000\") & vbLf &\n                                \"W\" & Format(PlcOutStartAddress + 7, \"0000\")\n        Try\n            iReturnCode = ACT_PLC1.ReadDeviceRandom2(szDeviceName, Arrysize, sharrDeviceValue(0))\n        Catch exException As Exception\n            'Exception processing\n            MessageBox.Show(exException.Message, Name, MessageBoxButtons.OK, MessageBoxIcon.Error)\n            Exit Sub\n        End Try\n\n        'When the ReadDeviceRandom2 method is succeeded, display the read data.\n        If iReturnCode = 0 Then\n\n            'Copy the read data to the 'lpszarrData'.\n            For iNumber = 0 To iNumberOfDeviceName - 1\n                szarrData(iNumber) = sharrDeviceValue(iNumber).ToString()\n            Next iNumber\n            For i = 0 To Arrysize - 1\n                PLC_VALUE(i) = CInt(sharrDeviceValue(i))\n            Next i\n\n            PlcDw(PlcInStartAddress) = PLC_VALUE(0)\n            PlcDw(PlcInStartAddress + 1) = PLC_VALUE(1)\n            PlcDw(PlcInStartAddress + 2) = PLC_VALUE(2)\n\n            PlcDw(PlcOutStartAddress) = PLC_VALUE(3)\n            PlcDw(PlcOutStartAddress + 1) = PLC_VALUE(4)\n            PlcDw(PlcOutStartAddress + 2) = PLC_VALUE(5)\n            PlcDw(PlcOutStartAddress + 3) = PLC_VALUE(6)\n            PlcDw(PlcOutStartAddress + 4) = PLC_VALUE(7)\n            PlcDw(PlcOutStartAddress + 5) = PLC_VALUE(8)\n\n            VALUE_IN_LABEL(0).Text = PlcDw(PlcInStartAddress)\n            VALUE_IN_LABEL(1).Text = PlcDw(PlcInStartAddress + 1)\n            VALUE_IN_LABEL(2).Text = PlcDw(PlcInStartAddress + 2)\n\n            VALUE_OUT_LABEL(0).Text = PlcDw(PlcOutStartAddress)\n            VALUE_OUT_LABEL(1).Text = PlcDw(PlcOutStartAddress + 1)\n            VALUE_OUT_LABEL(2).Text = PlcDw(PlcOutStartAddress + 2)\n            VALUE_OUT_LABEL(3).Text = PlcDw(PlcOutStartAddress + 3)\n            VALUE_OUT_LABEL(4).Text = PlcDw(PlcOutStartAddress + 4)\n            VALUE_OUT_LABEL(5).Text = PlcDw(PlcOutStartAddress + 5)\n\n            For j = 0 To 2\n                If VALUE_IN_LABEL(j).Text = \"0\" Then\n                    VALUE_IN_LABEL(j).ForeColor = Color.Black\n                    VALUE_IN_LABEL(j).BackColor = Color.White\n                Else\n                    VALUE_IN_LABEL(j).ForeColor = Color.White\n                    VALUE_IN_LABEL(j).BackColor = Color.Black\n                End If\n            Next\n            For j = 0 To 5\n                If VALUE_OUT_LABEL(j).Text = \"0\" Then\n                    VALUE_OUT_LABEL(j).ForeColor = Color.Black\n                    VALUE_OUT_LABEL(j).BackColor = Color.White\n                Else\n                    VALUE_OUT_LABEL(j).ForeColor = Color.White\n                    VALUE_OUT_LABEL(j).BackColor = Color.Black\n                End If\n            Next\n            tError1 = \"OK\"\n\n        Else\n\n            tError1 = Dec2Hex(iReturnCode)\n\n        End If\n\n    End Sub\n\n    Private Sub PLC_WRITE_1(ByVal strChr As String, ByVal StartArry As String, ByVal ArryMessage As String)\n\n        Dim iReturnCode As Integer              'Return code\n        Dim szDeviceName As String = \"\"         'List data for 'DeviceName'\n        Dim sharrDeviceValue() As Short          'Data for 'DeviceValue'\n\n        ReDim sharrDeviceValue(Len(ArryMessage))\n\n        For i As Integer = 0 To Len(ArryMessage) - 1\n            szDeviceName = szDeviceName & strChr & Format((Int(StartArry) + i), \"0000\")\n            'If i <> Len(ArryMessage - 1) Then szDeviceName = szDeviceName + ControlChars.Lf\n            If i < Len(ArryMessage) - 1 Then szDeviceName = szDeviceName & ControlChars.Lf\n            sharrDeviceValue(i) = Mid(ArryMessage, i + 1, 1)\n        Next\n\n        Try\n\n            iReturnCode = ACT_PLC1.WriteDeviceRandom2(szDeviceName, Len(ArryMessage), sharrDeviceValue(0))\n\n        Catch exception As Exception\n\n            'Exception processing\n            'MessageBox.Show(exception.Message, Text, MessageBoxButtons.OK, MessageBoxIcon.Error)\n            Flag_Connection_PLC1 = False\n            Exit Sub\n\n        End Try\n\n        'The return code of the method is displayed by the hexadecimal.\n        'txt_ReturnCode.Text = String.Format(\"0x{0:x8} [HEX]\", iReturnCode)\n\n    End Sub\n\n    Private Sub PlcConnect()\n\n        'ACT_PLC1.ActSourceNetworkNumber = 1\n        'ACT_PLC1.ActSourceStationNumber = 2\n        'ACT_PLC1.ActNetworkNumber = 1\n        'ACT_PLC1.ActStationNumber = 1\n        ACT_PLC1.ActCpuType = 211\n\n        ACT_PLC1.ActHostAddress = Address_Connection_PLC1\n        If ACT_PLC1.Open <> 0 Then\n            Flag_Connection_PLC1 = False\n        Else\n            Flag_Connection_PLC1 = True\n        End If\n\n    End Sub\n\n    Private Sub Load_Part(ByVal str As String)\n\n        ConnectionOpenSql()\n        Dim i As Integer\n        Dim Rs As New ADODB.Recordset\n\n        Rs.CursorLocation = ADODB.CursorLocationEnum.adUseClient\n        Rs.CursorType = ADODB.CursorTypeEnum.adOpenStatic\n        Rs.LockType = ADODB.LockTypeEnum.adLockOptimistic\n\n        Rs.Open(\"SELECT * FROM Table_Part WHERE Part_No = '\" & str & \"'\", SqlConnect)\n\n        If Rs.RecordCount = 1 Then\n\n            StartTime = Format(Now, \"HH:mm:ss\")\n\n            Panel_PartNo.Text = Rs.Fields(\"Part_No\").Value\n            Panel_PartName.Text = Trim(Rs.Fields(\"Part_Name\").Value)\n            Panel_CarType.Text = Trim(Rs.Fields(\"Option_CarType\").Value)\n            Panel_Position.Text = Trim(Rs.Fields(\"Option_LHRH\").Value)\n            LoadPicture(Picture_Main, Panel_PartNo.Text)\n\n            'HGT (o), Undertray (o) = 6\n            'HGT (o), Undertray (x) = 4\n            'N/HGT (o), Undertray (o) = 6\n            'N/HGT (o), Undertray (x) = 4\n\n            If Panel_CarType.Text.Contains(\"SEMI\") = True Then\n                Panel_HGT.Text = \"N/HGT\"\n                Panel_Pump_VAlue.Text = \"NA\"\n                Panel_Pump_DEC.Text = \"NA\"\n                Panel_Pump_DEC.BackColor = Color.Green\n                Panel_TQ1_DEC.Text = \"NA\"\n                Panel_TQ1_DEC.BackColor = Color.Green\n                Panel_TQ2_DEC.Text = \"NA\"\n                Panel_TQ2_DEC.BackColor = Color.Green\n                Panel_TQ3_DEC.Text = \"NA\"\n                Panel_TQ3_DEC.BackColor = Color.Green\n                Panel_TQ4_DEC.Text = \"NA\"\n                Panel_TQ4_DEC.BackColor = Color.Green\n                Panel_TQ5_DEC.Text = \"NA\"\n                Panel_TQ5_DEC.BackColor = Color.Green\n                Panel_TQ1.Text = \"NA\"\n                Panel_TQ2.Text = \"NA\"\n                Panel_TQ3.Text = \"NA\"\n                Panel_TQ4.Text = \"NA\"\n                Panel_TQ5.Text = \"NA\"\n            Else\n                If Rs.Fields(\"OPtion_HGT\").Value = True Then\n                    Panel_HGT.Text = \"HGT\"\n                ElseIf Rs.Fields(\"OPtion_HGT\").Value = False And Rs.Fields(\"Option_UNDERTRAY\").Value = True Then\n                    Panel_HGT.Text = \"N/HGT\"\n                    Panel_Pump_VAlue.Text = \"NA\"\n                    Panel_Pump_DEC.Text = \"NA\"\n                    Panel_Pump_DEC.BackColor = Color.Green\n                    Panel_TQ1_DEC.Text = \"NA\"\n                    Panel_TQ1_DEC.BackColor = Color.Green\n                    Panel_TQ2_DEC.Text = \"NA\"\n                    Panel_TQ2_DEC.BackColor = Color.Green\n                    Panel_TQ3_DEC.Text = \"NA\"\n                    Panel_TQ3_DEC.BackColor = Color.Green\n                    Panel_TQ4_DEC.Text = \"NA\"\n                    Panel_TQ4_DEC.BackColor = Color.Green\n                    Panel_TQ5_DEC.Text = \"NA\"\n                    Panel_TQ5_DEC.BackColor = Color.Green\n                    Panel_TQ1.Text = \"NA\"\n                    Panel_TQ2.Text = \"NA\"\n                    Panel_TQ3.Text = \"NA\"\n                    Panel_TQ4.Text = \"NA\"\n                    Panel_TQ5.Text = \"NA\"\n                ElseIf Rs.Fields(\"OPtion_HGT\").Value = False And Rs.Fields(\"Option_UNDERTRAY\").Value = False Then\n                    Panel_HGT.Text = \"N/HGT\"\n                    Panel_Pump_VAlue.Text = \"NA\"\n                    Panel_Pump_DEC.Text = \"NA\"\n                    Panel_Pump_DEC.BackColor = Color.Green\n                    Panel_TQ1_DEC.Text = \"NA\"\n                    Panel_TQ1_DEC.BackColor = Color.Green\n                    Panel_TQ2_DEC.Text = \"NA\"\n                    Panel_TQ2_DEC.BackColor = Color.Green\n                    Panel_TQ3_DEC.Text = \"NA\"\n                    Panel_TQ3_DEC.BackColor = Color.Green\n                    Panel_TQ4_DEC.Text = \"NA\"\n                    Panel_TQ4_DEC.BackColor = Color.Green\n                    Panel_TQ5_DEC.Text = \"NA\"\n                    Panel_TQ5_DEC.BackColor = Color.Green\n                    Panel_TQ1.Text = \"NA\"\n                    Panel_TQ2.Text = \"NA\"\n                    Panel_TQ3.Text = \"NA\"\n                    Panel_TQ4.Text = \"NA\"\n                    Panel_TQ5.Text = \"NA\"\n                End If\n\n            End If\n\n            If Rs.Fields(\"Option_VENT\").Value = True Then\n                Panel_Vent.Text = \"VENT\"\n            Else\n                Panel_Vent.Text = \"-\"\n                Panel_Blower_DEC.Text = \"NA\"\n                Panel_Blower_Value.Text = \"NA\"\n            End If\n\n            If Rs.Fields(\"Option_WARMER\").Value = True Then\n                Panel_Warmer.Text = \"WARMER\"\n            Else\n                Panel_Warmer.Text = \"-\"\n            End If\n\n            If Rs.Fields(\"Option_UNDERTRAY\").Value = True Then\n                Panel_Undertray.Text = \"UNDERTRAY\"\n            Else\n                Panel_Undertray.Text = \"-\"\n            End If\n\n            If Rs.Fields(\"Option_CAN\").Value = True Then\n                Panel_Can.Text = \"CAN\"\n            Else\n                Panel_Can.Text = \"-\"\n            End If\n\n            If Trim(Rs.Fields(\"OPTION_BLOWER_BARCODE\").Value) = \"0\" Then\n                TargetBlower.Text = \"NA\"\n                Panel_Blower_Value.Text = \"NA\"\n                Panel_Blower_DEC.Text = \"NA\"\n                Panel_Blower_DEC.BackColor = Color.Green\n            Else\n                OPTION_BLOWER_BARCODE = Trim(Rs.Fields(\"OPTION_BLOWER_BARCODE\").Value)\n                TargetBlower.Text = OPTION_BLOWER_BARCODE\n                Panel_Blower_Value.Text = \"\"\n                Panel_Blower_DEC.Text = \"\"\n                Panel_Blower_DEC.BackColor = Color.White\n            End If\n\n            If Panel_CarType.Text.Contains(\"SEMI\") Then\n                Panel_Pump_VAlue.Text = \"NA\"\n                Panel_Pump_DEC.Text = \"NA\"\n                Panel_Pump_DEC.BackColor = Color.Green\n            End If\n\n            wStep = 4\n            LoadPicture(Picture_Main, Panel_PartNo.Text)\n\n        End If\n\n        Rs.ActiveConnection = Nothing\n        Rs.Close()\n\n        ConnectionCloseSql()\n\n    End Sub\n\n    Private Sub Save_DB(snstr As String)\n\n        wStep = wStep + 0.001\n        Dim strSQL As String\n\n        ConnectionOpenSql()\n\n        strSQL = \"UPDATE TABLE_MAIN SET \" &\n                    \"S50_START_DATE = '\" & Format(Now, \"yyyy-MM-dd\") & \"',\" &\n                    \"S50_START_TIME = '\" & StartTime & \"',\" &\n                    \"S50_END_TIME = '\" & Format(Now, \"HH:mm:ss\") & \"',\" &\n                    \"S50_PUMP_SERIAL = '\" & Panel_Pump_VAlue.Text & \"',\" &\n                    \"S50_BLOWER_SERIAL = '\" & Panel_Blower_Value.Text & \"',\" &\n                    \"S50_TQ1 = '\" & Panel_TQ1.Text & \"',\" &\n                    \"S50_TQ2 = '\" & Panel_TQ2.Text & \"',\" &\n                    \"S50_TQ3 = '\" & Panel_TQ3.Text & \"',\" &\n                    \"S50_TQ4 = '\" & Panel_TQ4.Text & \"',\" &\n                    \"S50_TQ5 = '\" & Panel_TQ5.Text & \"',\" &\n                    \"S50_DECISION = '\" & \"OK\" & \"' \" &\n                    \"WHERE SERIAL_NUMBER = '\" & snstr & \"'\"\n\n        SqlConnect.Execute(strSQL)\n        ConnectionCloseSql()\n        wStep = 9.1\n    End Sub\n\n    Private Function CheckDuplicated(strcolName As String, strVAl As String) As Boolean\n\n        Dim tmp As Boolean = False\n\n        Dim Rs As New ADODB.Recordset\n        Rs.CursorLocation = ADODB.CursorLocationEnum.adUseClient\n        Rs.CursorType = ADODB.CursorTypeEnum.adOpenStatic\n        Rs.LockType = ADODB.LockTypeEnum.adLockOptimistic\n        Rs.Open(\"SELECT * FROM Table_Main Where \" & strcolName & \" = '\" & strVAl & \"'\", SqlConnect)\n        If Rs.RecordCount >= 1 Then\n            tmp = True\n        End If\n        Rs.ActiveConnection = Nothing\n        Rs.Close()\n\n        Return tmp\n\n    End Function\n\n    Private Function CheckBlowerDuplicated(strScanDAta As String) As Boolean\n\n        Dim FlagReturn As Boolean = False\n        ConnectionOpenSql()\n\n        Dim Rs As New ADODB.Recordset\n        Dim tmp As String\n\n        Rs.CursorLocation = ADODB.CursorLocationEnum.adUseClient\n        Rs.CursorType = ADODB.CursorTypeEnum.adOpenStatic\n        Rs.LockType = ADODB.LockTypeEnum.adLockOptimistic\n\n        Rs.Open(\"SELECT * FROM Table_Main where S50_BLOWER_SERIAL = '\" & strScanDAta & \"'\", SqlConnect)\n\n        If Rs.RecordCount >= 1 Then\n            FlagReturn = True\n        End If\n\n        Rs.ActiveConnection = Nothing\n        Rs.Close()\n\n        ConnectionCloseSql()\n\n        If FlagDuplicateCheck Then\n            If Panel_Rework.Text = \"REWORK\" Then\n                Return False\n            Else\n                Return FlagReturn\n            End If\n        Else\n            Return False\n        End If\n\n    End Function\n\n    Private Function CheckPumpDuplicated(strScanDAta As String) As Boolean\n\n        Dim FlagReturn As Boolean = False\n        ConnectionOpenSql()\n\n        Dim Rs As New ADODB.Recordset\n        Dim tmp As String\n\n        Rs.CursorLocation = ADODB.CursorLocationEnum.adUseClient\n        Rs.CursorType = ADODB.CursorTypeEnum.adOpenStatic\n        Rs.LockType = ADODB.LockTypeEnum.adLockOptimistic\n\n        Rs.Open(\"SELECT * FROM Table_Main where S50_PUMP_SERIAL = '\" & strScanDAta & \"'\", SqlConnect)\n\n        If Rs.RecordCount >= 1 Then\n            FlagReturn = True\n        End If\n\n        Rs.ActiveConnection = Nothing\n        Rs.Close()\n\n        ConnectionCloseSql()\n\n        If FlagDuplicateCheck Then\n            If Panel_Rework.Text = \"REWORK\" Then\n                Return False\n            Else\n                Return FlagReturn\n            End If\n        Else\n            Return False\n        End If\n\n    End Function\n\n    Private Sub Save_DB_Rework(Serial As String)\n\n        ConnectionOpenSql()\n\n        Dim Rs As New ADODB.Recordset\n        Dim tmp As String\n\n        Rs.CursorLocation = ADODB.CursorLocationEnum.adUseClient\n        Rs.CursorType = ADODB.CursorTypeEnum.adOpenStatic\n        Rs.LockType = ADODB.LockTypeEnum.adLockOptimistic\n\n        Rs.Open(\"SELECT * FROM Table_Main where SERIAL_NUMBER ='\" & Serial & \"'\", SqlConnect)\n\n        If Rs.RecordCount = 1 Then\n\n            tmp = Rs.Fields(\"REWORK\").Value\n            tmp = CStr(CInt(tmp) + 1)\n            Rs.Fields(\"REWORK\").Value = tmp\n            Rs.Update()\n\n        End If\n\n        Rs.ActiveConnection = Nothing\n        Rs.Close()\n\n        ConnectionCloseSql()\n\n    End Sub\n\n    Private Sub Tmr_Work_Tick(sender As Object, e As EventArgs) Handles Tmr_Work.Tick\n\n        Label_STep.Text = wStep\n\n        ' D_Value LED 업데이트\n        For i As Integer = 0 To 15\n            Try\n                If D_Value(i) = 0 Then\n                    LED_IN(i).Image = My.Resources.ResourceManager.GetObject(CStr(i) & \"-50\")\n                Else\n                    LED_IN(i).Image = My.Resources.ResourceManager.GetObject(CStr(i) & \" Filled-50\")\n                End If\n            Catch ex As Exception\n            End Try\n        Next i\n\n        If PLC_VALUE(0) = 0 And wStep <> 0 Then\n            WorkPArt = Panel_PartNo.Text\n            InitControl()\n            If IMAGE_PART <> \"\" Then\n                FrmImage.Show()\n                FrmImage.Load_WorkImage(IMAGE_PART)\n            Else\n            End If\n            InitControl()\n            PLC_WRITE_1(\"W\", \"0450\", \"000000000\")\n            wStep = 0\n        End If\n\n        If wStep = 0 Then\n\n            If PLC_VALUE(0) = 1 Then\n                If FrmImage.Visible = True Then FrmImage.Close()\n                TIMER_COUNT = 0\n                Panel_RF_READ.Text = \"\"\n                'Panel_RF_UID.Text = \"\"\n                'frmimage.Close()\n                wStep = 1 '제품인\n            End If\n\n        ElseIf wStep = 1 Then\n\n            TIMER_COUNT = TIMER_COUNT + 0.1\n            If Panel_RF_READ.Text <> \"\" Then wStep = 1.5\n            If TIMER_COUNT > 2.0 Then\n                If Panel_RF_READ.Text = \"00000000000000000000000\" Then\n                    PLC_STRING_1 = \"000000000\"\n                    Mid(PLC_STRING_1, 5, 1) = \"3\"\n                    PLC_WRITE_1(\"W\", \"0450\", PLC_STRING_1)\n                    wStep = 10\n                End If\n            End If\n\n        ElseIf wStep = 1.5 Then\n\n            If Panel_RF_READ.Text <> \"\" Then\n                Panel_SN.Text = Panel_RF_READ.Text\n                If Panel_SN.Text = \"00000000000000000000000\" Then\n                    PLC_WRITE_1(\"W\", \"0454\", \"3\")\n                    wStep = 10\n                Else\n                    Check_BEFORE(Panel_SN.Text)\n                    'Panel_Before.Text = \"OK\"\n                    If Panel_Before.Text = \"OK\" Then\n                        If Panel_Rework.Text = \"\" Then\n                            Load_Part(Mid(Panel_SN.Text, 13, 11))\n                        ElseIf Panel_Rework.Text = \"REWORK\" And Panel_Now.Text = \"OK\" Then\n                            'wStep = 10\n                            'PLC_WRITE_1(\"W\", \"0454\", \"3\")\n                            'PLC_WRITE_1(\"W\", \"0455\", \"1\")s\n                            'wStep = 10\n                            REWORK_STOP = True\n                            Load_Part(Mid(Panel_SN.Text, 13, 11))\n\n                        ElseIf Panel_Rework.Text = \"REWORK\" And Panel_Now.Text = \"NG\" Then\n                            Load_Part(Mid(Panel_SN.Text, 13, 11))\n                        End If\n                    Else\n                        wStep = 10\n                        PLC_WRITE_1(\"W\", \"0454\", \"3\")\n                    End If\n                End If\n            End If\n\n        ElseIf wStep = 4 Then '사양 PLC 전달\n\n            PLC_STRING_1 = \"000000000\"\n\n            If Panel_Position.Text = \"LH\" Then\n                Mid(PLC_STRING_1, 1, 1) = \"1\"\n            ElseIf Panel_Position.Text = \"RH\" Then\n                Mid(PLC_STRING_1, 1, 1) = \"2\"\n            End If\n\n            If Panel_HGT.Text = \"HGT\" Then\n                Mid(PLC_STRING_1, 2, 1) = \"1\"\n            ElseIf Panel_HGT.Text = \"N/HGT\" Then\n                Mid(PLC_STRING_1, 2, 1) = \"2\"\n            End If\n\n            If Panel_Vent.Text = \"VENT\" Then\n                Mid(PLC_STRING_1, 3, 1) = \"1\"\n            Else\n                Mid(PLC_STRING_1, 3, 1) = \"2\"\n            End If\n\n            If Panel_CarType.Text.Contains(\"KY\") = True Then\n                Mid(PLC_STRING_1, 4, 1) = \"1\"\n            Else\n                Mid(PLC_STRING_1, 4, 1) = \"2\"\n            End If\n\n            If Panel_Warmer.Text = \"WARMER\" Then\n                Mid(PLC_STRING_1, 7, 1) = \"1\"\n            Else\n                Mid(PLC_STRING_1, 7, 1) = \"2\"\n            End If\n\n            If Panel_Undertray.Text = \"UNDERTRAY\" Then\n                Mid(PLC_STRING_1, 8, 1) = \"1\"\n            Else\n                Mid(PLC_STRING_1, 8, 1) = \"2\"\n            End If\n\n            If Panel_Can.Text = \"CAN\" Then\n                Mid(PLC_STRING_1, 9, 1) = \"1\"\n            Else\n                Mid(PLC_STRING_1, 9, 1) = \"2\"\n            End If\n\n            Mid(PLC_STRING_1, 5, 1) = \"1\"\n            PLC_WRITE_1(\"W\", \"0450\", PLC_STRING_1)\n            IMAGE_PART = Panel_PartNo.Text\n            wStep = 4.1\n\n        ElseIf wStep = 4.1 Then\n\n            If PLC_VALUE(6) = 1 Or PLC_VALUE(6) = 2 Then\n                wStep = 4.9\n            Else\n                wStep = 4\n            End If\n\n        ElseIf wStep = 4.9 Then\n\n            If REWORK_STOP = True Then\n                PLC_WRITE_1(\"W\", \"0455\", \"1\")\n                wStep = 9\n            Else\n                wStep = 5\n            End If\n\n        ElseIf wStep = 5 Then\n\n            If Panel_CarType.Text.Contains(\"SEMI\") = True And Panel_CarType.Text.Contains(\"KY\") = True Then\n                toolstep = 1000\n                wStep = 7\n            Else\n                ' HGT/NHGT × LH/RH × QY/KY 조합으로 CurrentToolP 결정\n                Dim isLH As Boolean = (Panel_Position.Text = \"LH\")\n                Dim isKY As Boolean = Panel_CarType.Text.Contains(\"KY\")\n\n                If Panel_HGT.Text = \"HGT\" Then\n                    If isLH Then\n                        If isKY Then CurrentToolP = Hgt_LH_KY Else CurrentToolP = Hgt_LH_QY\n                    Else\n                        If isKY Then CurrentToolP = Hgt_RH_KY Else CurrentToolP = Hgt_RH_QY\n                    End If\n                    If Tool1UseCheck <> False Then\n                        toolstep = 100\n                        pos1.Text = CurrentToolP(0)\n                        pos2.Text = CurrentToolP(1)\n                        pos3.Text = CurrentToolP(2)\n                        pos4.Text = CurrentToolP(3)\n                        pos5.Text = CurrentToolP(4)\n                        wStep = 6\n                    Else\n                        toolstep = 1000\n                        wStep = 7\n                    End If\n                ElseIf Panel_HGT.Text = \"N/HGT\" Then\n                    If isLH Then\n                        If isKY Then CurrentToolP = NHgt_LH_KY Else CurrentToolP = NHgt_LH_QY\n                    Else\n                        If isKY Then CurrentToolP = NHgt_RH_KY Else CurrentToolP = NHgt_RH_QY\n                    End If\n                    toolstep = 10\n                    pos1.Text = CurrentToolP(0)\n                    pos2.Text = CurrentToolP(1)\n                    pos3.Text = CurrentToolP(2)\n                    pos4.Text = CurrentToolP(3)\n                    pos5.Text = CurrentToolP(4)\n                    wStep = 6\n                End If\n            End If\n\n        ElseIf wStep = 6 Then 'TOOL - toolstep 기반 IO 조건 확인\n            ' toolstep=1000이면 모든 TQ 완료\n            If toolstep = 1000 Then\n                wStep = 7\n            End If\n\n        ElseIf wStep = 7 Then\n\n            If (Panel_Pump_DEC.Text = \"NA\" Or Panel_Pump_DEC.Text = \"OK\") Or\n               (Panel_Blower_DEC.Text = \"NA\" Or Panel_Blower_DEC.Text = \"OK\") Then\n                wStep = 9\n            End If\n\n        ElseIf wStep = 9 Then 'SEND PLC COMPLETE\n\n            If (Panel_Pump_DEC.Text = \"OK\" Or Panel_Pump_DEC.Text = \"NA\") And\n                        (Panel_Blower_DEC.Text = \"OK\" Or Panel_Blower_DEC.Text = \"NA\") Then\n                Panel_Total_DEC.Text = \"OK\"\n                Panel_Total_DEC.BackColor = Color.Blue\n                PLC_WRITE_1(\"W\", \"0455\", \"1\")\n                Save_DB(Panel_SN.Text)\n            End If\n\n        ElseIf wStep = 9.1 Then\n\n            If PLC_VALUE(7) = 1 Then\n                wStep = 10\n            Else\n                wStep = 9\n            End If\n\n        ElseIf wStep = 10 Then\n\n            If PLC_VALUE(0) = 0 And PLC_VALUE(1) = 0 Then\n                PLC_WRITE_1(\"W\", \"0450\", \"000000000\")\n                wStep = 11\n            End If\n\n        ElseIf wStep = 11 Then\n\n            InitControl()\n            If IMAGE_PART <> \"\" Then\n                FrmImage.Show()\n                FrmImage.Load_WorkImage(IMAGE_PART)\n            Else\n            End If\n            wStep = 0\n\n        End If\n\n    End Sub\n    Private Sub Check_BEFORE(strSN As String)\n\n        ConnectionOpenSql()\n\n        Dim Rs As New ADODB.Recordset\n\n        Rs.CursorLocation = ADODB.CursorLocationEnum.adUseClient\n        Rs.CursorType = ADODB.CursorTypeEnum.adOpenStatic\n        Rs.LockType = ADODB.LockTypeEnum.adLockOptimistic\n\n        Rs.Open(\"SELECT * FROM Table_Main where SERIAL_NUMBER ='\" & strSN & \"'\", SqlConnect)\n\n        If Rs.RecordCount = 1 Then\n\n            Try\n                Panel_Before.Text = Trim(Rs.Fields(\"S40_DECISION\").Value)\n                Panel_Before.BackColor = Color.Blue\n            Catch ex As Exception\n                Panel_Before.Text = \"NG\"\n                Panel_Before.BackColor = Color.Red\n            End Try\n\n\n            Try\n                If Trim(Rs.Fields(\"REWORK\").Value) = \"0\" Then\n                    Panel_Rework.BackColor = Color.White\n                Else\n                    Panel_Rework.Text = \"REWORK\"\n                    Panel_Rework.BackColor = Color.Black\n                End If\n            Catch ex As Exception\n\n            End Try\n\n            If Panel_Rework.Text = \"REWORK\" Then\n\n                Try\n                    Panel_Now.Text = Trim(Rs.Fields(\"S50_DECISION\").Value)\n                    Panel_Now.BackColor = Color.Blue\n                Catch ex As Exception\n                    Panel_Now.Text = \"NG\"\n                    Panel_Now.BackColor = Color.Red\n                End Try\n\n            End If\n\n        End If\n\n        Rs.ActiveConnection = Nothing\n        Rs.Close()\n\n        ConnectionCloseSql()\n\n    End Sub\n    Private Sub Control_2_Arry()\n\n        LED_IN(0) = P_IN0\n        LED_IN(1) = P_IN1\n        LED_IN(2) = P_IN2\n        LED_IN(3) = P_IN3\n        LED_IN(4) = P_IN4\n        LED_IN(5) = P_IN5\n        LED_IN(6) = P_IN6\n        LED_IN(7) = P_IN7\n\n        LED_IN(8) = P_IN8\n        LED_IN(9) = P_IN9\n        LED_IN(10) = P_IN10\n        LED_IN(11) = P_IN11\n        LED_IN(12) = P_IN12\n        LED_IN(13) = P_IN13\n        LED_IN(14) = P_IN14\n        LED_IN(15) = P_IN15\n\n        LED_OUT(0) = P_OUT0\n        LED_OUT(1) = P_OUT1\n        LED_OUT(2) = P_OUT2\n        LED_OUT(3) = P_OUT3\n        LED_OUT(4) = P_OUT4\n        LED_OUT(5) = P_OUT5\n        LED_OUT(6) = P_OUT6\n        LED_OUT(7) = P_OUT7\n\n    End Sub\n\n    ' IO 조건 확인 함수 (\"번호_ON/번호_OFF\" 형식)\n    Private Function CheckIOCondition(str As String) As Boolean\n        If String.IsNullOrWhiteSpace(str) Then Return True\n\n        Dim conditions() As String = str.Split(\"/\"c)\n\n        For Each cond As String In conditions\n            cond = cond.Trim()\n            If String.IsNullOrEmpty(cond) Then Continue For\n\n            Dim parts() As String = cond.Split(\"_\"c)\n            If parts.Length <> 2 Then Return False\n\n            Dim ioNumber As Integer\n            If Not Integer.TryParse(parts(0), ioNumber) Then Return False\n\n            Dim expectedValue As Integer\n            If parts(1).ToUpper() = \"ON\" Then\n                expectedValue = 1\n            ElseIf parts(1).ToUpper() = \"OFF\" Then\n                expectedValue = 0\n            Else\n                Return False\n            End If\n\n            If ioNumber < 0 OrElse ioNumber >= D_Value.Length Then Return False\n\n            If D_Value(ioNumber) <> expectedValue Then\n                Return False\n            End If\n        Next\n\n        Return True\n    End Function\n    Private Function STR2ASC(ByVal str As String) As String\n\n        Dim tmp As String = \"\"\n        Dim i As Integer\n\n        For i = 1 To Len(str)\n            tmp = tmp & Hex(Asc(Mid(str, i, 1)))\n        Next\n\n        Return tmp\n\n    End Function\n\n    Private Function ASC2STR(ByVal str As String) As String\n\n        Dim One_Hex, Tmp_Hex, i, retVal\n        For i = 1 To Len(str)\n            One_Hex = Mid(str, i, 1)\n            If IsNumeric(One_Hex) Then\n                Tmp_Hex = Mid(str, i, 2)\n                i = i + 1\n            Else\n                Tmp_Hex = Mid(str, i, 4)\n                i = i + 3\n            End If\n            retVal = retVal & Chr(\"&H\" & Tmp_Hex)\n        Next\n        Return retVal\n\n    End Function\n\n    Private Sub Button6_Click(sender As Object, e As EventArgs) Handles Button6.Click\n        InitControl()\n        wStep = 0\n    End Sub\n\n    Private appMutex As Mutex\n\n    Private Sub FrmMain_Load(ByVal sender As Object, ByVal e As System.EventArgs) Handles Me.Load\n\n        'Private appMutex As Mutex\n        Dim createdNew As Boolean = False\n        appMutex = New Mutex(True, \"Name\", createdNew)\n        If Not createdNew Then\n            Environment.Exit(0)\n        End If\n\n        ExecuteQurryMDB(\"ALTER TABLE Table_basic ADD FlagDuplicateCheck BIT\")\n\n        ' ACT_PLC1 ActiveX 컨트롤 코드로 생성 (디자이너 오류 방지)\n        ACT_PLC1 = New AxACTETHERLib.AxActQNUDECPUTCP()\n        CType(ACT_PLC1, System.ComponentModel.ISupportInitialize).BeginInit()\n        ACT_PLC1.Enabled = True\n        ACT_PLC1.Location = New System.Drawing.Point(1384, 5)\n        ACT_PLC1.Name = \"ACT_PLC1\"\n        ACT_PLC1.Size = New System.Drawing.Size(32, 32)\n        Panel6.Controls.Add(ACT_PLC1)\n        CType(ACT_PLC1, System.ComponentModel.ISupportInitialize).EndInit()\n\n        gConnectionOpenSql()\n        Dim i As Short\n        LoadBasicData()\n        InitControl()\n\n        FLag_ONOFF = False\n        Control_2_Arry()\n\n        ' INI 파일에서 툴 IO 조건 로드 (HGT/NHGT × LH/RH × QY/KY 8가지 조합)\n        Dim iniSections() As String = {\"TOOL_HGT_LH_QY\", \"TOOL_HGT_LH_KY\",\n                                       \"TOOL_HGT_RH_QY\", \"TOOL_HGT_RH_KY\",\n                                       \"TOOL_NHGT_LH_QY\", \"TOOL_NHGT_LH_KY\",\n                                       \"TOOL_NHGT_RH_QY\", \"TOOL_NHGT_RH_KY\"}\n\n        If Not System.IO.File.Exists(iniFilePath) Then\n            ' INI 파일 신규 생성\n            Dim sw As New System.IO.StreamWriter(iniFilePath, False, System.Text.Encoding.Default)\n            sw.WriteLine(\"[SET]\")\n            sw.WriteLine(\"DuplicatedCheck=0\")\n            sw.WriteLine(\"\")\n            For Each sec As String In iniSections\n                sw.WriteLine(\"[\" & sec & \"]\")\n                sw.WriteLine(\"P1=\")\n                sw.WriteLine(\"P2=\")\n                sw.WriteLine(\"P3=\")\n                sw.WriteLine(\"P4=\")\n                sw.WriteLine(\"P5=\")\n                sw.WriteLine(\"\")\n            Next\n            sw.Close()\n        Else\n            ' 기존 파일에 없는 섹션만 추가\n            Dim fileContent As String = System.IO.File.ReadAllText(iniFilePath, System.Text.Encoding.Default)\n            For Each sec As String In iniSections\n                If Not fileContent.Contains(\"[\" & sec & \"]\") Then\n                    Dim sw As New System.IO.StreamWriter(iniFilePath, True, System.Text.Encoding.Default)\n                    sw.WriteLine(\"\")\n                    sw.WriteLine(\"[\" & sec & \"]\")\n                    sw.WriteLine(\"P1=\")\n                    sw.WriteLine(\"P2=\")\n                    sw.WriteLine(\"P3=\")\n                    sw.WriteLine(\"P4=\")\n                    sw.WriteLine(\"P5=\")\n                    sw.Close()\n                End If\n            Next\n        End If\n\n        Dim iniFile As New IniFile(iniFilePath)\n        ' 8가지 조합 IO 조건 로드\n        Hgt_LH_QY(0) = iniFile.ReadValue(\"TOOL_HGT_LH_QY\", \"P1\", \"\")\n        Hgt_LH_QY(1) = iniFile.ReadValue(\"TOOL_HGT_LH_QY\", \"P2\", \"\")\n        Hgt_LH_QY(2) = iniFile.ReadValue(\"TOOL_HGT_LH_QY\", \"P3\", \"\")\n        Hgt_LH_QY(3) = iniFile.ReadValue(\"TOOL_HGT_LH_QY\", \"P4\", \"\")\n        Hgt_LH_QY(4) = iniFile.ReadValue(\"TOOL_HGT_LH_QY\", \"P5\", \"\")\n\n        Hgt_LH_KY(0) = iniFile.ReadValue(\"TOOL_HGT_LH_KY\", \"P1\", \"\")\n        Hgt_LH_KY(1) = iniFile.ReadValue(\"TOOL_HGT_LH_KY\", \"P2\", \"\")\n        Hgt_LH_KY(2) = iniFile.ReadValue(\"TOOL_HGT_LH_KY\", \"P3\", \"\")\n        Hgt_LH_KY(3) = iniFile.ReadValue(\"TOOL_HGT_LH_KY\", \"P4\", \"\")\n        Hgt_LH_KY(4) = iniFile.ReadValue(\"TOOL_HGT_LH_KY\", \"P5\", \"\")\n\n        Hgt_RH_QY(0) = iniFile.ReadValue(\"TOOL_HGT_RH_QY\", \"P1\", \"\")\n        Hgt_RH_QY(1) = iniFile.ReadValue(\"TOOL_HGT_RH_QY\", \"P2\", \"\")\n        Hgt_RH_QY(2) = iniFile.ReadValue(\"TOOL_HGT_RH_QY\", \"P3\", \"\")\n        Hgt_RH_QY(3) = iniFile.ReadValue(\"TOOL_HGT_RH_QY\", \"P4\", \"\")\n        Hgt_RH_QY(4) = iniFile.ReadValue(\"TOOL_HGT_RH_QY\", \"P5\", \"\")\n\n        Hgt_RH_KY(0) = iniFile.ReadValue(\"TOOL_HGT_RH_KY\", \"P1\", \"\")\n        Hgt_RH_KY(1) = iniFile.ReadValue(\"TOOL_HGT_RH_KY\", \"P2\", \"\")\n        Hgt_RH_KY(2) = iniFile.ReadValue(\"TOOL_HGT_RH_KY\", \"P3\", \"\")\n        Hgt_RH_KY(3) = iniFile.ReadValue(\"TOOL_HGT_RH_KY\", \"P4\", \"\")\n        Hgt_RH_KY(4) = iniFile.ReadValue(\"TOOL_HGT_RH_KY\", \"P5\", \"\")\n\n        NHgt_LH_QY(0) = iniFile.ReadValue(\"TOOL_NHGT_LH_QY\", \"P1\", \"\")\n        NHgt_LH_QY(1) = iniFile.ReadValue(\"TOOL_NHGT_LH_QY\", \"P2\", \"\")\n        NHgt_LH_QY(2) = iniFile.ReadValue(\"TOOL_NHGT_LH_QY\", \"P3\", \"\")\n        NHgt_LH_QY(3) = iniFile.ReadValue(\"TOOL_NHGT_LH_QY\", \"P4\", \"\")\n        NHgt_LH_QY(4) = iniFile.ReadValue(\"TOOL_NHGT_LH_QY\", \"P5\", \"\")\n\n        NHgt_LH_KY(0) = iniFile.ReadValue(\"TOOL_NHGT_LH_KY\", \"P1\", \"\")\n        NHgt_LH_KY(1) = iniFile.ReadValue(\"TOOL_NHGT_LH_KY\", \"P2\", \"\")\n        NHgt_LH_KY(2) = iniFile.ReadValue(\"TOOL_NHGT_LH_KY\", \"P3\", \"\")\n        NHgt_LH_KY(3) = iniFile.ReadValue(\"TOOL_NHGT_LH_KY\", \"P4\", \"\")\n        NHgt_LH_KY(4) = iniFile.ReadValue(\"TOOL_NHGT_LH_KY\", \"P5\", \"\")\n\n        NHgt_RH_QY(0) = iniFile.ReadValue(\"TOOL_NHGT_RH_QY\", \"P1\", \"\")\n        NHgt_RH_QY(1) = iniFile.ReadValue(\"TOOL_NHGT_RH_QY\", \"P2\", \"\")\n        NHgt_RH_QY(2) = iniFile.ReadValue(\"TOOL_NHGT_RH_QY\", \"P3\", \"\")\n        NHgt_RH_QY(3) = iniFile.ReadValue(\"TOOL_NHGT_RH_QY\", \"P4\", \"\")\n        NHgt_RH_QY(4) = iniFile.ReadValue(\"TOOL_NHGT_RH_QY\", \"P5\", \"\")\n\n        NHgt_RH_KY(0) = iniFile.ReadValue(\"TOOL_NHGT_RH_KY\", \"P1\", \"\")\n        NHgt_RH_KY(1) = iniFile.ReadValue(\"TOOL_NHGT_RH_KY\", \"P2\", \"\")\n        NHgt_RH_KY(2) = iniFile.ReadValue(\"TOOL_NHGT_RH_KY\", \"P3\", \"\")\n        NHgt_RH_KY(3) = iniFile.ReadValue(\"TOOL_NHGT_RH_KY\", \"P4\", \"\")\n        NHgt_RH_KY(4) = iniFile.ReadValue(\"TOOL_NHGT_RH_KY\", \"P5\", \"\")\n\n        ' 모듈 출력 초기화\n        D_OutString = \"S00000000E\"\n\n        FLAG_RFID_RUN = False\n        RF_READ_COUNT = 0\n\n        ACT_PLC1.ActTimeOut = 5