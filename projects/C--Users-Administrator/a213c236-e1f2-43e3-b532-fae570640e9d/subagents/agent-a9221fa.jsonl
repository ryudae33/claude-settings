nd()\n        $cmd.CommandText = \"SELECT * FROM [$sheetName]\"\n        $adapter = New-Object System.Data.OleDb.OleDbDataAdapter($cmd)\n        $dt = New-Object System.Data.DataTable\n        $adapter.Fill($dt) | Out-Null\n\n        Write-Host \"Rows: $($dt.Rows.Count), Cols: $($dt.Columns.Count)\"\n\n        $limit = [Math]::Min($dt.Rows.Count, 200)\n\n        for ($r = 0; $r -lt $limit; $r++) {\n            $rowData = @()\n            for ($c = 0; $c -lt $dt.Columns.Count; $c++) {\n                $val = $dt.Rows[$r][$c]\n                if ($val -eq [DBNull]::Value) { $val = \"\" }\n                $val = \"$val\".Trim()\n                $rowData += $val\n            }\n            $line = $rowData -join \"|\"\n            $cleaned = $line -replace '\\|', ''\n            if ($cleaned.Trim() -ne \"\") {\n                Write-Host \"R$($r): $line\"\n            }\n        }\n\n        if ($dt.Rows.Count -gt 200) {\n            Write-Host \"... remaining $($dt.Rows.Count - 200) rows omitted\"\n        }\n\n        $dt.Dispose()\n        $cmd.Dispose()\n    }\n    catch {\n        Write-Host \"ERROR reading sheet: $($_.Exception.Message)\"\n    }\n}\n\n$conn.Close()\n$conn.Dispose()\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1170,"cache_read_input_tokens":35183,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1170},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"}},"requestId":"req_011CYK3XsurQELcBJNqh6RJ5","type":"assistant","uuid":"17bcef62-8f71-47ac-9238-40290f7091b4","timestamp":"2026-02-20T08:58:22.063Z"}
