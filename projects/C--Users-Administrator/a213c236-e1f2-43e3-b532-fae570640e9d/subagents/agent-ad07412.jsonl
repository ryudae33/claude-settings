   }\n        $line = $rowData -join \"|\"\n        if ($line.Trim(\"|\").Trim() -ne \"\") {\n            Write-Host (\"[R$r] \" + $line)\n        }\n    }\n    \n    if ($dt.Rows.Count -gt 150) {\n        Write-Host (\"... remaining \" + ($dt.Rows.Count - 150) + \" rows omitted\")\n    }\n    \n    $dt.Dispose()\n    $cmd.Dispose()\n}\n\n$conn.Close()\n$conn.Dispose()\nPSEOF\npowershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\Administrator\\temp_read_excel2.ps1\" 2>&1","description":"OleDb로 Excel 파일 읽기","timeout":120000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":816,"cache_read_input_tokens":16087,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":816},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"}},"requestId":"req_011CYK3QaiZ4TovQKUjjcaPc","type":"assistant","uuid":"8941da62-d036-4be9-b7d1-caeb82933b02","timestamp":"2026-02-20T08:56:38.303Z"}
