 -Force -ErrorAction SilentlyContinue\nWrite-Host \"Done - 탐색기 재시작됨\"\nPS1","description":"HKCU 레지스트리로 파일 연결 변경 + 탐색기 재시작"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":9991,"cache_read_input_tokens":123387,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":9991},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"}},"requestId":"req_011CYDkuaWxRrhLBFdp7czAW","type":"assistant","uuid":"651b3f5a-1251-40fb-aafa-4b1a2ff7e713","timestamp":"2026-02-17T13:57:20.595Z"}
