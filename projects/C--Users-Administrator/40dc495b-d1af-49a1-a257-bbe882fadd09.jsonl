{"parentUuid":"2d2f02df-cbf0-4563-8ce5-12a969540fec","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator","sessionId":"40dc495b-d1af-49a1-a257-bbe882fadd09","version":"2.1.44","gitBranch":"HEAD","slug":"joyful-sleeping-rabbit","message":{"model":"claude-opus-4-6","id":"msg_01NdSWpQnTcwDbMvasw5VMJB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Fa9dK2p6Ju1A41nvNTicpw","name":"Write","input":{"file_path":"C:\\Users\\Administrator\\bin\\gdrive-sync.sh","content":"#!/bin/bash\n# gdrive-sync: Git 리포지토리의 문서/DB 파일을 Google Drive와 동기화\n# 사용법:\n#   gdrive-sync push   - 로컬 → Google Drive 업로드\n#   gdrive-sync pull   - Google Drive → 로컬 다운로드\n#   gdrive-sync status - Google Drive 폴더 내용 확인\n\nREMOTE=\"gdrive-tmp\"\nBASE_DIR=\"github-ignore\"\n\n# 문서/DB 확장자 목록\nEXTENSIONS=\"xlsx xls doc docx pdf hwp hwpx ppt pptx csv db mdb accdb sqlite\"\n\n# 리포 이름 자동 감지\nget_repo_name() {\n    local url\n    url=$(git remote get-url origin 2>/dev/null)\n    if [ -z \"$url\" ]; then\n        echo \"오류: git 리포지토리가 아니거나 origin 리모트가 없습니다.\" >&2\n        exit 1\n    fi\n    # URL에서 리포 이름 추출 (org/repo.git → repo)\n    basename \"$url\" .git\n}\n\nREPO=$(get_repo_name)\nDRIVE_PATH=\"${REMOTE}:${BASE_DIR}/${REPO}\"\n\n# include 필터 생성\nbuild_includes() {\n    local args=\"\"\n    for ext in $EXTENSIONS; do\n        args=\"$args --include=**.${ext}\"\n    done\n    # 임시 엑셀 파일 제외\n    args=\"$args --exclude=~\\$*\"\n    args=\"$args --exclude=**\"\n    echo \"$args\"\n}\n\ncase \"${1}\" in\n    push)\n        echo \"[$REPO] 로컬 → Google Drive 업로드 중...\"\n        echo \"대상: $DRIVE_PATH\"\n        eval rclone copy . \"\\\"$DRIVE_PATH\\\"\" $(build_includes) --progress\n        echo \"업로드 완료.\"\n        ;;\n    pull)\n        echo \"[$REPO] Google Drive → 로컬 다운로드 중...\"\n        echo \"소스: $DRIVE_PATH\"\n        rclone copy \"$DRIVE_PATH\" . --progress\n        echo \"다운로드 완료.\"\n        ;;\n    status)\n        echo \"[$REPO] Google Drive 파일 목록:\"\n        rclone ls \"$DRIVE_PATH\" 2>/dev/null\n        if [ $? -ne 0 ]; then\n            echo \"(폴더 없음 - push로 먼저 업로드하세요)\"\n        fi\n        ;;\n    *)\n        echo \"사용법: gdrive-sync {push|pull|status}\"\n        echo \"\"\n        echo \"  push   - 문서/DB 파일을 Google Drive에 업로드\"\n        echo \"  pull   - Google Drive에서 문서/DB 파일 다운로드\"\n        echo \"  status - Google Drive 파일 목록 확인\"\n        echo \"\"\n        echo \"리포: $REPO\"\n        echo \"드라이브: $DRIVE_PATH\"\n        exit 1\n        ;;\nesac\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":445,"cache_read_input_tokens":85499,"output_tokens":892,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":445,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"requestId":"req_011CYDjjY9vs2wffre51RrcV","type":"assistant","uuid":"2e935724-0661-4db0-9f2f-1176f040cf63","timestamp":"2026-02-17T13:41:57.715Z"}
