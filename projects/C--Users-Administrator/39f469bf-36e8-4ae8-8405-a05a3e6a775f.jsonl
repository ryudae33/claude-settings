0→    public event Action<double, int> AngleReceived;\n    51→\n    52→    #region 속성\n    53→\n    54→    /// <summary>연결 상태</summary>\n    55→    public bool IsConnected => _isConnected;\n    56→\n    57→    /// <summary>현재 각도 (0~359.99°, 오프셋 적용)</summary>\n    58→    public double Degree\n    59→    {\n    60→        get { lock (_lock) { return _degree; } }\n    61→    }\n    62→\n    63→    /// <summary>현재 절대 카운트 (오프셋 적용)</summary>\n    64→    public int Count\n    65→    {\n    66→        get { lock (_lock) { return _count; } }\n    67→    }\n    68→\n    69→    /// <summary>수신 카운트</summary>\n    70→    public long ReceiveCount => _receiveCount;\n    71→\n    72→    /// <summary>파싱 성공 카운트</summary>\n    73→    public long ParseSuccessCount => _parseSuccessCount;\n    74→\n    75→    /// <summary>인코더 이름 (config.ini 섹션 구분용)</summary>\n    76→    public string EncoderName\n    77→    {\n    78→        get => _encoderName;\n    79→        set => _encoderName = value;\n    80→    }\n    81→\n    82→    #endregion\n    83→\n    84→    #region 로그\n    85→\n    86→    public void SetLogCallback(Action<string> callback) { _logCallback = callback; }\n    87→\n    88→    private void Log(string message)\n    89→    {\n    90→        try { _logCallback?.Invoke($\"[Esp32Enc] {message}\"); } catch { }\n    91→    }\n    92→\n    93→    #endregion\n    94→\n    95→    #region 연결/해제\n    96→\n    97→    /// <summary>시리얼 포트 연결 (921600bps)</summary>\n    98→    public bool Connect(string portName)\n    99→    {\n   100→        try\n   101→        {\n   102→            Log($\"Connect 시도: {portName}\");\n   103→\n   104→            if (_isConnected) DisconnectInternal();\n   105→\n   106→            if (string.IsNullOrEmpty(portName) || portName == \"Disabled\")\n   107→            {\n   108→                Log(\"포트명이 비어있거나 Disabled\");\n   109→                return false;\n   110→            }\n   111→\n   112→            _portName = portName;\n   113→            _receiveCount = 0;\n   114→            _parseSuccessCount = 0;\n   115→            _parseFailCount = 0;\n   116→            _buffer.Clear();\n   117→\n   118→            _serialPort = new SerialPort(portName, 921600, Parity.None, 8, StopBits.One)\n   119→            {\n   120→                DtrEnable = false,\n   121→                RtsEnable = false,\n   122→                ReadTimeout = 100,\n   123→                ReadBufferSize = 8192,\n   124→                WriteBufferSize = 1024\n   125→            };\n   126→\n   127→            _serialPort.Open();\n   128→            Log($\"포트 열림 OK\");\n   129→\n   130→            _isConnected = true;\n   131→            _keepReading = true;\n   132→\n   133→            _readThread = new Thread(ReadSerialThread) { IsBackground = true };\n   134→            _readThread.Start();\n   135→\n   136→            StartReconnectMonitor();\n   137→            LoadOffset();\n   138→            return true;\n   139→        }\n   140→        catch (Exception ex)\n   141→        {\n   142→            Log($\"Connect 예외: {ex.GetType().Name} - {ex.Message}\");\n   143→            _isConnected = false;\n   144→            _serialPort?.Dispose();\n   145→            _serialPort = null;\n   146→            return false;\n   147→        }\n   148→    }\n   149→\n   150→    /// <summary>연결 해제</summary>\n   151→    public void Disconnect()\n   152→    {\n   153→        Log($\"Disconnect - 수신:{_receiveCount}, 파싱성공:{_parseSuccessCount}, 실패:{_parseFailCount}\");\n   154→        StopReconnectMonitor();\n   155→        DisconnectInternal();\n   156→    }\n   157→\n   158→    private void DisconnectInternal()\n   159→    {\n   160→        _keepReading = false;\n   161→\n   162→        _readThread?.Join(500);\n   163→        _readThread = null;\n   164→\n   165→        if (_serialPort != null)\n   166→        {\n   167→            try { if (_serialPort.IsOpen) _serialPort.Close(); _serialPort.Dispose(); }\n   168→            catch (Exception ex) { Log($\"포트 해제 예외: {ex.Message}\"); }\n   169→            _serialPort = null;\n   170→        }\n   171→        _isConnected = false;\n   172→    }\n   173→\n   174→    private void StartReconnectMonitor()\n   175→    {\n   176→        if (_reconnectThread != null && _reconnectThread.IsAlive) return;\n   177→        _keepReconnecting = true;\n   178→        _reconnectThread = new Thread(ReconnectMonitorThread) { IsBackground = true };\n   179→        _reconnectThread.Start();\n   180→    }\n   181→\n   182→    private void StopReconnectMonitor()\n   183→    {\n   184→        _keepReconnecting = false;\n   185→        _reconnectThread?.Join(1000);\n   186→        _reconnectThread = null;\n   187→    }\n   188→\n   189→    private void ReconnectMonitorThread()\n   190→    {\n   191→        while (_keepReconnecting)\n   192→        {\n   193→            try\n   194→            {\n   195→                Thread.Sleep(2000);\n   196→                if (!_keepReconnecting) break;\n   197→\n   198→                bool needReconnect = _serialPort == null || !_serialPort.IsOpen || !_isConnected;\n   199→                if (needReconnect && !string.IsNullOrEmpty(_portName) && _portName != \"Disabled\")\n   200→                {\n   201→                    Log($\"재연결 시도: {_portName}\");\n   202→                    DisconnectInternal();\n   203→                    Thread.Sleep(1000);\n   204→                    if (TryReconnect()) Log(\"재연결 성공\");\n   205→                }\n   206→            }\n   207→            catch (Exception ex) { Log($\"재연결 모니터 예외: {ex.Message}\"); }\n   208→        }\n   209→    }\n   210→\n   211→    private bool TryReconnect()\n   212→    {\n   213→        try\n   214→        {\n   215→            if (string.IsNullOrEmpty(_portName) || _portName == \"Disabled\") return false;\n   216→            bool found = false;\n   217→            foreach (var p in SerialPort.GetPortNames()) if (p == _portName) { found = true; break; }\n   218→            if (!found) return false;\n   219→\n   220→            _buffer.Clear();\n   221→            _serialPort = new SerialPort(_portName, 921600, Parity.None, 8, StopBits.One)\n   222→            {\n   223→                DtrEnable = false, RtsEnable = false,\n   224→                ReadTimeout = 100, ReadBufferSize = 8192\n   225→            };\n   226→            _serialPort.Open();\n   227→\n   228→            if (_serialPort.IsOpen)\n   229→            {\n   230→                _isConnected = true;\n   231→                _keepReading = true;\n   232→                _readThread = new Thread(ReadSerialThread) { IsBackground = true };\n   233→                _readThread.Start();\n   234→                LoadOffset();\n   235→                return true;\n   236→            }\n   237→            return false;\n   238→        }\n   239→        catch (Exception ex)\n   240→        {\n   241→            Log($\"TryReconnect 예외: {ex.Message}\");\n   242→            try { _serialPort?.Dispose(); } catch { }\n   243→            _serialPort = null;\n   244→            _isConnected = false;\n   245→            return false;\n   246→        }\n   247→    }\n   248→\n   249→    #endregion\n   250→\n   251→    #region 명령 전송\n   252→\n   253→    /// <summary>카운트를 0으로 리셋 (NVS 미저장)</summary>\n   254→    public void SendZero() => SendCommand(\"ZERO\");\n   255→\n   256→    /// <summary>현재 위치를 절대 원점으로 NVS 저장</summary>\n   257→    public void SendSetHome() => SendCommand(\"SETHOME\");\n   258→\n   259→    /// <summary>현재 상태 즉시 출력 요청</summary>\n   260→    public void SendStatus() => SendCommand(\"STATUS\");\n   261→\n   262→    /// <summary>임의 명령 전송</summary>\n   263→    public void SendCommand(string cmd)\n   264→    {\n   265→        try\n   266→        {\n   267→            if (_isConnected && _serialPort != null && _serialPort.IsOpen)\n   268→            {\n   269→                Log($\"SendCommand: {cmd}\");\n   270→                _serialPort.WriteLine(cmd);\n   271→            }\n   272→            else\n   273→            {\n   274→                Log($\"SendCommand 실패 (연결안됨): {cmd}\");\n   275→            }\n   276→        }\n   277→        catch (Exception ex) { Log($\"SendCommand 예외: {ex.Message}\"); }\n   278→    }\n   279→\n   280→    #endregion\n   281→\n   282→    #region 시리얼 읽기/파싱\n   283→\n   284→    private void ReadSerialThread()\n   285→    {\n   286→        while (_keepReading && _serialPort != null && _serialPort.IsOpen)\n   287→        {\n   288→            try\n   289→            {\n   290→                int bytesToRead = _serialPort.BytesToRead;\n   291→\n   292→                if (bytesToRead > 4096)\n   293→                {\n   294→                    Log($\"버퍼 오버플로우({bytesToRead}), 클리어\");\n   295→                    _serialPort.DiscardInBuffer();\n   296→                    _buffer.Clear();\n   297→                    continue;\n   298→                }\n   299→\n   300→                if (bytesToRead == 0) { Thread.Sleep(5); continue; }\n   301→\n   302→                string incoming = _serialPort.ReadExisting();\n   303→                if (string.IsNullOrEmpty(incoming)) { Thread.Sleep(5); continue; }\n   304→\n   305→                _receiveCount++;\n   306→                _buffer.Append(incoming);\n   307→\n   308→                // 줄 단위 추출\n   309→                string data = _buffer.ToString();\n   310→                int lastNl = data.LastIndexOf('\\n');\n   311→                if (lastNl < 0) lastNl = data.LastIndexOf('\\r');\n   312→                if (lastNl < 0) continue;\n   313→\n   314→                string complete = data.Substring(0, lastNl);\n   315→                _buffer.Clear();\n   316→                _buffer.Append(data.Substring(lastNl + 1));\n   317→\n   318→                foreach (string line in complete.Split(new[] { '\\r', '\\n' }, StringSplitOptions.RemoveEmptyEntries))\n   319→                {\n   320→                    string t = line.Trim();\n   321→                    if (t.StartsWith(\"{\") && t.EndsWith(\"}\"))\n   322→                        ParseJson(t);\n   323→                }\n   324→            }\n   325→            catch (TimeoutException) { }\n   326→            catch (InvalidOperationException ex) { Log($\"연결 끊김: {ex.Message}\"); _isConnected = false; break; }\n   327→            catch (System.IO.IOException ex)     { Log($\"케이블 분리: {ex.Message}\"); _isConnected = false; break; }\n   328→            catch (Exception ex)                 { Log($\"ReadThread 예외: {ex.GetType().Name} - {ex.Message}\"); _isConnected = false; }\n   329→        }\n   330→    }\n   331→\n   332→    /// <summary>\n   333→    /// JSON 파싱\n   334→    /// 실시간 데이터: {\"t\":12345,\"cnt\":2048,\"deg\":180.00,\"ok\":true}\n   335→    /// 명령 응답: {\"cmd\":\"ZERO\",\"ok\":true} 등 → 로그만 출력\n   336→    /// </summary>\n   337→    private void ParseJson(string json)\n   338→    {\n   339→        try\n   340→        {\n   341→            // 명령 응답은 로그만\n   342→            if (json.Contains(\"\\\"cmd\\\"\"))\n   343→            {\n   344→                Log($\"CMD 응답: {json}\");\n   345→                return;\n   346→            }\n   347→\n   348→            // 부팅 메시지\n   349→            if (json.Contains(\"\\\"msg\\\"\"))\n   350→            {\n   351→                Log($\"부팅: {json}\");\n   352→                return;\n   353→            }\n   354→\n   355→            // 실시간 데이터: \"deg\" 필드 추출\n   356→            double deg = 0;\n   357→            int cnt = 0;\n   358→            bool parsedDeg = false;\n   359→\n   360→            int degIdx = json.IndexOf(\"\\\"deg\\\":\");\n   361→            if (degIdx >= 0)\n   362→            {\n   363→                int start = degIdx + 6;\n   364→                int end = json.IndexOfAny(new[] { ',', '}' }, start);\n   365→                if (end > start)\n   366→                    parsedDeg = double.TryParse(\n   367→                        json.Substring(start, end - start).Trim(),\n   368→                        System.Globalization.NumberStyles.Any,\n   369→                        System.Globalization.CultureInfo.InvariantCulture, out deg);\n   370→            }\n   371→\n   372→            if (!parsedDeg)\n   373→            {\n   374→                _parseFailCount++;\n   375→                if (_parseFailCount <= 10) Log($\"파싱 실패 #{_parseFailCount}: [{json}]\");\n   376→                return;\n   377→            }\n   378→\n   379→            // cnt 필드 추출 (선택)\n   380→            int cntIdx = json.IndexOf(\"\\\"cnt\\\":\");\n   381→            if (cntIdx >= 0)\n   382→            {\n   383→                int start = cntIdx + 6;\n   384→                int end = json.IndexOfAny(new[] { ',', '}' }, start);\n   385→                if (end > start)\n   386→                    int.TryParse(json.Substring(start, end - start).Trim(), out cnt);\n   387→            }\n   388→\n   389→            _parseSuccessCount++;\n   390→\n   391→            lock (_lock)\n   392→            {\n   393→                _degree = deg;\n   394→                _count  = cnt - _offsetCount;\n   395→            }\n   396→\n   397→            // 이벤트 발생 (UI 업데이트용)\n   398→            AngleReceived?.Invoke(deg, cnt - _offsetCount);\n   399→        }\n   400→        catch (Exception ex)\n   401→        {\n   402→            _parseFailCount++;\n   403→            Log($\"ParseJson 예외: {ex.Message}, JSON=[{json}]\");\n   404→        }\n   405→    }\n   406→\n   407→    #endregion\n   408→\n   409→    #region 원점 오프셋 저장/로드\n   410→\n   411→    /// <summary>현재 카운트를 원점(0)으로 설정 (프로그램 내 오프셋, NVS 미저장)</summary>\n   412→    public void SetProgramHome()\n   413→    {\n   414→        lock (_lock) { _offsetCount = _count + _offsetCount; }\n   415→        SaveOffset();\n   416→        Log($\"[프로그램 원점] offset={_offsetCount}\");\n   417→    }\n   418→\n   419→    private void SaveOffset()\n   420→    {\n   421→        try\n   422→        {\n   423→            if (string.IsNullOrEmpty(_encoderName)) return;\n   424→            string iniPath = System.AppDomain.CurrentDomain.BaseDirectory + \"config.ini\";\n   425→            var ini = new IniFile(iniPath);\n   426→            ini.WriteValue($\"Encoder_{_encoderName}\", \"OffsetCount\", _offsetCount.ToString());\n   427→            Log($\"[오프셋 저장] offset={_offsetCount}\");\n   428→        }\n   429→        catch (Exception ex) { Log($\"SaveOffset 예외: {ex.Message}\"); }\n   430→    }\n   431→\n   432→    private void LoadOffset()\n   433→    {\n   434→        try\n   435→        {\n   436→            if (string.IsNullOrEmpty(_encoderName)) return;\n   437→            string iniPath = System.AppDomain.CurrentDomain.BaseDirectory + \"config.ini\";\n   438→            var ini = new IniFile(iniPath);\n   439→            string s = ini.ReadValue($\"Encoder_{_encoderName}\", \"OffsetCount\");\n   440→            if (!string.IsNullOrEmpty(s) && int.TryParse(s, out int o))\n   441→            {\n   442→                lock (_lock) { _offsetCount = o; }\n   443→                Log($\"[오프셋 로드] offset={o}\");\n   444→            }\n   445→        }\n   446→        catch (Exception ex) { Log($\"LoadOffset 예외: {ex.Message}\"); }\n   447→    }\n   448→\n   449→    #endregion\n   450→\n   451→    public void Dispose() => Disconnect();\n   452→}\n   453→"}]},"uuid":"909ac239-c120-4b9f-a91b-6dbc2eb7d4fc","timestamp":"2026-03-02T23:33:27.370Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\Administrator\\Desktop\\DAESUNG_FINETECH\\NoiseTest_Daesung\\ClassEsp32Encoder.cs","content":"using System;\nusing System.IO.Ports;\nusing System.Text;\nusing System.Threading;\n\n/// <summary>\n/// ESP32 싱글 엔코더 통신 클래스\n/// 대상: Autonics E40H8-1024-3-T-24 + ESP32\n/// 921600bps, JSON 프로토콜, 100Hz\n/// 수신 형식: {\"t\":12345,\"cnt\":2048,\"deg\":180.00,\"ok\":true}\n/// </summary>\npublic class ClassEsp32Encoder\n{\n    // 시리얼 포트\n    private SerialPort _serialPort;\n    private bool _isConnected = false;\n    private Thread _readThread;\n    private bool _keepReading = false;\n\n    // 자동 재연결\n    private string _portName = \"\";\n    private Thread _reconnectThread;\n    private bool _keepReconnecting = false;\n\n    // 엔코더 값\n    private double _degree = 0;   // 각도 (0~359.99°)\n    private int    _count  = 0;   // 절대 카운트 (원점 기준, 음수 가능)\n\n    // 프로그램 원점 오프셋\n    private int _offsetCount = 0;\n\n    // 수신 버퍼\n    private StringBuilder _buffer = new StringBuilder();\n\n    // 동기화 락\n    private object _lock = new object();\n\n    // 로그 콜백\n    private Action<string> _logCallback = null;\n\n    // 수신 카운터\n    private long _receiveCount = 0;\n    private long _parseSuccessCount = 0;\n    private long _parseFailCount = 0;\n\n    // 인코더 이름 (config.ini 섹션 구분용)\n    private string _encoderName = \"\";\n\n    /// <summary>각도 수신 이벤트 (deg, cnt)</summary>\n    public event Action<double, int> AngleReceived;\n\n    #region 속성\n\n    /// <summary>연결 상태</summary>\n    public bool IsConnected => _isConnected;\n\n    /// <summary>현재 각도 (0~359.99°, 오프셋 적용)</summary>\n    public double Degree\n    {\n        get { lock (_lock) { return _degree; } }\n    }\n\n    /// <summary>현재 절대 카운트 (오프셋 적용)</summary>\n    public int Count\n    {\n        get { lock (_lock) { return _count; } }\n    }\n\n    /// <summary>수신 카운트</summary>\n    public long ReceiveCount => _receiveCount;\n\n    /// <summary>파싱 성공 카운트</summary>\n    public long ParseSuccessCount => _parseSuccessCount;\n\n    /// <summary>인코더 이름 (config.ini 섹션 구분용)</summary>\n    public string EncoderName\n    {\n        get => _encoderName;\n        set => _encoderName = value;\n    }\n\n    #endregion\n\n    #region 로그\n\n    public void SetLogCallback(Action<string> callback) { _logCallback = callback; }\n\n    private void Log(string message)\n    {\n        try { _logCallback?.Invoke($\"[Esp32Enc] {message}\"); } catch { }\n    }\n\n    #endregion\n\n    #region 연결/해제\n\n    /// <summary>시리얼 포트 연결 (921600bps)</summary>\n    public bool Connect(string portName)\n    {\n        try\n        {\n            Log($\"Connect 시도: {portName}\");\n\n            if (_isConnected) DisconnectInternal();\n\n            if (string.IsNullOrEmpty(portName) || portName == \"Disabled\")\n            {\n                Log(\"포트명이 비어있거나 Disabled\");\n                return false;\n            }\n\n            _portName = portName;\n            _receiveCount = 0;\n            _parseSuccessCount = 0;\n            _parseFailCount = 0;\n            _buffer.Clear();\n\n            _serialPort = new SerialPort(portName, 921600, Parity.None, 8, StopBits.One)\n            {\n                DtrEnable = false,\n                RtsEnable = false,\n                ReadTimeout = 100,\n                ReadBufferSize = 8192,\n                WriteBufferSize = 1024\n            };\n\n            _serialPort.Open();\n            Log($\"포트 열림 OK\");\n\n            _isConnected = true;\n            _keepReading = true;\n\n            _readThread = new Thread(ReadSerialThread) { IsBackground = true };\n            _readThread.Start();\n\n            StartReconnectMonitor();\n            LoadOffset();\n            return true;\n        }\n        catch (Exception ex)\n        {\n            Log($\"Connect 예외: {ex.GetType().Name} - {ex.Message}\");\n            _isConnected = false;\n            _serialPort?.Dispose();\n            _serialPort = null;\n            return false;\n        }\n    }\n\n    /// <summary>연결 해제</summary>\n    public void Disconnect()\n    {\n        Log($\"Disconnect - 수신:{_receiveCount}, 파싱성공:{_parseSuccessCount}, 실패:{_parseFailCount}\");\n        StopReconnectMonitor();\n        DisconnectInternal();\n    }\n\n    private void DisconnectInternal()\n    {\n        _keepReading = false;\n\n        _readThread?.Join(500);\n        _readThread = null;\n\n        if (_serialPort != null)\n        {\n            try { if (_serialPort.IsOpen) _serialPort.Close(); _serialPort.Dispose(); }\n            catch (Exception ex) { Log($\"포트 해제 예외: {ex.Message}\"); }\n            _serialPort = null;\n        }\n        _isConnected = false;\n    }\n\n    private void StartReconnectMonitor()\n    {\n        if (_reconnectThread != null && _reconnectThread.IsAlive) return;\n        _keepReconnecting = true;\n        _reconnectThread = new Thread(ReconnectMonitorThread) { IsBackground = true };\n        _reconnectThread.Start();\n    }\n\n    private void StopReconnectMonitor()\n    {\n        _keepReconnecting = false;\n        _reconnectThread?.Join(1000);\n        _reconnectThread = null;\n    }\n\n    private void ReconnectMonitorThread()\n    {\n        while (_keepReconnecting)\n        {\n            try\n            {\n                Thread.Sleep(2000);\n                if (!_keepReconnecting) break;\n\n                bool needReconnect = _serialPort == null || !_serialPort.IsOpen || !_isConnected;\n                if (needReconnect && !string.IsNullOrEmpty(_portName) && _portName != \"Disabled\")\n                {\n                    Log($\"재연결 시도: {_portName}\");\n                    DisconnectInternal();\n                    Thread.Sleep(1000);\n                    if (TryReconnect()) Log(\"재연결 성공\");\n                }\n            }\n            catch (Exception ex) { Log($\"재연결 모니터 예외: {ex.Message}\"); }\n        }\n    }\n\n    private bool TryReconnect()\n    {\n        try\n        {\n            if (string.IsNullOrEmpty(_portName) || _portName == \"Disabled\") return false;\n            bool found = false;\n            foreach (var p in SerialPort.GetPortNames()) if (p == _portName) { found = true; break; }\n            if (!found) return false;\n\n            _buffer.Clear();\n            _serialPort = new SerialPort(_portName, 921600, Parity.None, 8, StopBits.One)\n            {\n                DtrEnable = false, RtsEnable = false,\n                ReadTimeout = 100, ReadBufferSize = 8192\n            };\n            _serialPort.Open();\n\n            if (_serialPort.IsOpen)\n            {\n                _isConnected = true;\n                _keepReading = true;\n                _readThread = new Thread(ReadSerialThread) { IsBackground = true };\n                _readThread.Start();\n                LoadOffset();\n                return true;\n            }\n            return false;\n        }\n        catch (Exception ex)\n        {\n            Log($\"TryReconnect 예외: {ex.Message}\");\n            try { _serialPort?.Dispose(); } catch { }\n            _serialPort = null;\n            _isConnected = false;\n            return false;\n        }\n    }\n\n    #endregion\n\n    #region 명령 전송\n\n    /// <summary>카운트를 0으로 리셋 (NVS 미저장)</summary>\n    public void SendZero() => SendCommand(\"ZERO\");\n\n    /// <summary>현재 위치를 절대 원점으로 NVS 저장</summary>\n    public void SendSetHome() => SendCommand(\"SETHOME\");\n\n    /// <summary>현재 상태 즉시 출력 요청</summary>\n    public void SendStatus() => SendCommand(\"STATUS\");\n\n    /// <summary>임의 명령 전송</summary>\n    public void SendCommand(string cmd)\n    {\n        try\n        {\n            if (_isConnected && _serialPort != null && _serialPort.IsOpen)\n            {\n                Log($\"SendCommand: {cmd}\");\n                _serialPort.WriteLine(cmd);\n            }\n            else\n            {\n                Log($\"SendCommand 실패 (연결안됨): {cmd}\");\n            }\n        }\n        catch (Exception ex) { Log($\"SendCommand 예외: {ex.Message}\"); }\n    }\n\n    #endregion\n\n    #region 시리얼 읽기/파싱\n\n    private void ReadSerialThread()\n    {\n        while (_keepReading && _serialPort != null && _serialPort.IsOpen)\n        {\n            try\n            {\n                int bytesToRead = _serialPort.BytesToRead;\n\n                if (bytesToRead > 4096)\n                {\n                    Log($\"버퍼 오버플로우({bytesToRead}), 클리어\");\n                    _serialPort.DiscardInBuffer();\n                    _buffer.Clear();\n                    continue;\n                }\n\n                if (bytesToRead == 0) { Thread.Sleep(5); continue; }\n\n                string incoming = _serialPort.ReadExisting();\n                if (string.IsNullOrEmpty(incoming)) { Thread.Sleep(5); continue; }\n\n                _receiveCount++;\n                _buffer.Append(incoming);\n\n                // 줄 단위 추출\n                string data = _buffer.ToString();\n                int lastNl = data.LastIndexOf('\\n');\n                if (lastNl < 0) lastNl = data.LastIndexOf('\\r');\n                if (lastNl < 0) continue;\n\n                string complete = data.Substring(0, lastNl);\n                _buffer.Clear();\n                _buffer.Append(data.Substring(lastNl + 1));\n\n                foreach (string line in complete.Split(new[] { '\\r', '\\n' }, StringSplitOptions.RemoveEmptyEntries))\n                {\n                    string t = line.Trim();\n                    if (t.StartsWith(\"{\") && t.EndsWith(\"}\"))\n                        ParseJson(t);\n                }\n            }\n            catch (TimeoutException) { }\n            catch (InvalidOperationException ex) { Log($\"연결 끊김: {ex.Message}\"); _isConnected = false; break; }\n            catch (System.IO.IOException ex)     { Log($\"케이블 분리: {ex.Message}\"); _isConnected = false; break; }\n            catch (Exception ex)                 { Log($\"ReadThread 예외: {ex.GetType().Name} - {ex.Message}\"); _isConnected = false; }\n        }\n    }\n\n    /// <summary>\n    /// JSON 파싱\n    /// 실시간 데이터: {\"t\":12345,\"cnt\":2048,\"deg\":180.00,\"ok\":true}\n    /// 명령 응답: {\"cmd\":\"ZERO\",\"ok\":true} 등 → 로그만 출력\n    /// </summary>\n    private void ParseJson(string json)\n    {\n        try\n        {\n            // 명령 응답은 로그만\n            if (json.Contains(\"\\\"cmd\\\"\"))\n            {\n                Log($\"CMD 응답: {json}\");\n                return;\n            }\n\n            // 부팅 메시지\n            if (json.Contains(\"\\\"msg\\\"\"))\n            {\n                Log($\"부팅: {json}\");\n                return;\n            }\n\n            // 실시간 데이터: \"deg\" 필드 추출\n            double deg = 0;\n            int cnt = 0;\n            bool parsedDeg = false;\n\n            int degIdx = json.IndexOf(\"\\\"deg\\\":\");\n            if (degIdx >= 0)\n            {\n                int start = degIdx + 6;\n                int end = json.IndexOfAny(new[] { ',', '}' }, start);\n                if (end > start)\n                    parsedDeg = double.TryParse(\n                        json.Substring(start, end - start).Trim(),\n                        System.Globalization.NumberStyles.Any,\n                        System.Globalization.CultureInfo.InvariantCulture, out deg);\n            }\n\n            if (!parsedDeg)\n            {\n                _parseFailCount++;\n                if (_parseFailCount <= 10) Log($\"파싱 실패 #{_parseFailCount}: [{json}]\");\n                return;\n            }\n\n            // cnt 필드 추출 (선택)\n            int cntIdx = json.IndexOf(\"\\\"cnt\\\":\");\n            if (cntIdx >= 0)\n            {\n                int start = cntIdx + 6;\n                int end = json.IndexOfAny(new[] { ',', '}' }, start);\n                if (end > start)\n                    int.TryParse(json.Substring(start, end - start).Trim(), out cnt);\n            }\n\n            _parseSuccessCount++;\n\n            lock (_lock)\n            {\n                _degree = deg;\n                _count  = cnt - _offsetCount;\n            }\n\n            // 이벤트 발생 (UI 업데이트용)\n            AngleReceived?.Invoke(deg, cnt - _offsetCount);\n        }\n        catch (Exception ex)\n        {\n            _parseFailCount++;\n            Log($\"ParseJson 예외: {ex.Message}, JSON=[{json}]\");\n        }\n    }\n\n    #endregion\n\n    #region 원점 오프셋 저장/로드\n\n    /// <summary>현재 카운트를 원점(0)으로 설정 (프로그램 내 오프셋, NVS 미저장)</summary>\n    public void SetProgramHome()\n    {\n        lock (_lock) { _offsetCount = _count + _offsetCount; }\n        SaveOffset();\n        Log($\"[프로그램 원점] offset={_offsetCount}\");\n    }\n\n    private void SaveOffset()\n    {\n        try\n        {\n            if (string.IsNullOrEmpty(_encoderName)) return;\n            string iniPath = System.AppDomain.CurrentDomain.BaseDirectory + \"config.ini\";\n            var ini = new IniFile(iniPath);\n            ini.WriteValue($\"Encoder_{_encoderName}\", \"OffsetCount\", _offsetCount.ToString());\n            Log($\"[오프셋 저장] offset={_offsetCount}\");\n        }\n        catch (Exception ex) { Log($\"SaveOffset 예외: {ex.Message}\"); }\n    }\n\n    private void LoadOffset()\n    {\n        try\n        {\n            if (string.IsNullOrEmpty(_encoderName)) return;\n            string iniPath = System.AppDomain.CurrentDomain.BaseDirectory + \"config.ini\";\n            var ini = new IniFile(iniPath);\n            string s = ini.ReadValue($\"Encoder_{_encoderName}\", \"OffsetCount\");\n            if (!string.IsNullOrEmpty(s) && int.TryParse(s, out int o))\n            {\n                lock (_lock) { _offsetCount = o; }\n                Log($\"[오프셋 로드] offset={o}\");\n            }\n        }\n        catch (Exception ex) { Log($\"LoadOffset 예외: {ex.Message}\"); }\n    }\n\n    #endregion\n\n    public void Dispose() => Disconnect();\n}\n","numLines":453,"startLine":1,"totalLines":453}},"sourceToolAssistantUUID":"b0691773-972e-4ae4-820b-d27497794978"}
