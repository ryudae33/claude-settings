{"parentUuid":"73262ffa-e489-4b0a-b45e-9c23de3cd6a4","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator\\mcp-servers\\pcan","sessionId":"11039e2a-cbed-45eb-accf-f84d3fb4cdfe","version":"2.1.49","gitBranch":"HEAD","slug":"soft-wobbling-shannon","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CweK4k1zMeaAGopFnTAhqp","type":"tool_result","content":"File created successfully at: C:\\Users\\Administrator\\Desktop\\JX1\\rl_heater_quick.py"}]},"uuid":"3b945c27-cd6e-463d-a9e6-5fa43c977542","timestamp":"2026-02-20T10:12:58.888Z","toolUseResult":{"type":"create","filePath":"C:\\Users\\Administrator\\Desktop\\JX1\\rl_heater_quick.py","content":"\"\"\"\nRL 히터 빠른 테스트 - 3단 ON 후 충분한 대기시간으로 상태 확인\n\"\"\"\nimport ctypes\nfrom ctypes import Structure, c_uint32, c_uint8, c_uint16, byref\nimport threading, time\n\nclass TPCANMsg(Structure):\n    _fields_ = [(\"ID\", c_uint32), (\"MSGTYPE\", c_uint8), (\"LEN\", c_uint8), (\"DATA\", c_uint8 * 8)]\nclass TPCANTimestamp(Structure):\n    _fields_ = [(\"millis\", c_uint32), (\"millis_overflow\", c_uint16), (\"micros\", c_uint16)]\n\nPCAN_USBBUS1 = 0x51\nPCAN_BAUD_500K = 0x001C\nPCAN_ERROR_OK = 0\nPCAN_ERROR_QRCVEMPTY = 0x20\n\npcan = ctypes.windll.LoadLibrary(\"PCANBasic.dll\")\n_ign_running = False\n\ndef send(can_id, data):\n    msg = TPCANMsg(); msg.ID = can_id; msg.MSGTYPE = 0; msg.LEN = len(data)\n    for i in range(len(data)): msg.DATA[i] = data[i] & 0xFF\n    return pcan.CAN_Write(c_uint16(PCAN_USBBUS1), byref(msg))\n\ndef flush():\n    msg, ts = TPCANMsg(), TPCANTimestamp()\n    while pcan.CAN_Read(c_uint16(PCAN_USBBUS1), byref(msg), byref(ts)) == PCAN_ERROR_OK: pass\n\ndef ign_worker():\n    while _ign_running:\n        send(0x3E0, [0,0,0,0,0x50,0x03,0,0]); time.sleep(0.2)\n\ndef uds_req(data, timeout=2.0):\n    flush()\n    send(0x732, data)\n    msg, ts = TPCANMsg(), TPCANTimestamp()\n    dl = time.monotonic() + timeout\n    while time.monotonic() < dl:\n        s = pcan.CAN_Read(c_uint16(PCAN_USBBUS1), byref(msg), byref(ts))\n        if s == PCAN_ERROR_OK and msg.ID == 0x73A:\n            return [msg.DATA[i] for i in range(msg.LEN)]\n        elif s == PCAN_ERROR_QRCVEMPTY: time.sleep(0.001)\n    return None\n\ndef monitor(seconds, label=\"\"):\n    \"\"\"438h, 42Eh 변화 모니터링\"\"\"\n    print(f\"\\n  [{label}] {seconds}초 모니터링...\")\n    msg, ts = TPCANMsg(), TPCANTimestamp()\n    last_438 = last_42e = None\n    dl = time.monotonic() + seconds\n    start = time.monotonic()\n    while time.monotonic() < dl:\n        s = pcan.CAN_Read(c_uint16(PCAN_USBBUS1), byref(msg), byref(ts))\n        if s == PCAN_ERROR_OK:\n            data = [msg.DATA[i] for i in range(msg.LEN)]\n            data_hex = \" \".join(f\"{b:02X}\" for b in data)\n            elapsed = time.monotonic() - start\n            if msg.ID == 0x438 and data_hex != last_438:\n                ht = (data[0] >> 3) & 0xF\n                m = {2:\"OFF\",6:\"1단\",7:\"2단\",8:\"3단\"}.get(ht, f\"0x{ht:X}\")\n                print(f\"  [{elapsed:5.1f}s] 438h [{data_hex}] → 히터: {m}\")\n                last_438 = data_hex\n            elif msg.ID == 0x42E and data_hex != last_42e:\n                hi = (data[1]>>4)&3; mid = (data[1]>>6)&3; lo = data[2]&3\n                print(f\"  [{elapsed:5.1f}s] 42Eh [{data_hex}] → 3단={'ON' if hi else 'OFF'} 2단={'ON' if mid else 'OFF'} 1단={'ON' if lo else 'OFF'}\")\n                last_42e = data_hex\n        elif s == PCAN_ERROR_QRCVEMPTY:\n            time.sleep(0.001)\n\ndef main():\n    global _ign_running\n    print(\"=\" * 50)\n    print(\"  RL 히터 테스트\")\n    print(\"=\" * 50)\n\n    # 접속\n    s = pcan.CAN_Initialize(c_uint16(PCAN_USBBUS1), c_uint16(PCAN_BAUD_500K), c_uint8(0), c_uint32(0), c_uint16(0))\n    if s != PCAN_ERROR_OK:\n        print(f\"PCAN 접속 실패 (0x{s:X})\"); return\n    print(\"PCAN 접속 OK\")\n\n    try:\n        # IGN ON\n        _ign_running = True\n        threading.Thread(target=ign_worker, daemon=True).start()\n        print(\"IGN ON 시작\")\n        time.sleep(1.5)\n\n        # 초기 상태\n        monitor(2, \"초기 상태\")\n\n        # Extended Session\n        print(\"\\n  Extended Session 진입...\")\n        r = uds_req([0x02,0x10,0x03,0,0,0,0,0])\n        if r:\n            print(f\"  응답: [{' '.join(f'{b:02X}' for b in r)}] → {'OK' if r[1]==0x50 else 'FAIL'}\")\n        else:\n            print(\"  타임아웃\"); return\n\n        # TP 시작\n        _tp_running = True\n        def tp():\n            while _tp_running:\n                send(0x732,[0x02,0x3E,0x80,0,0,0,0,0]); time.sleep(2.0)\n        threading.Thread(target=tp, daemon=True).start()\n        time.sleep(0.3)\n\n        # 3단 ON\n        print(\"\\n  === 히터 3단 ON ===\")\n        r = uds_req([0x04,0x2F,0xF0,0x16,0x03,0,0,0])\n        if r:\n            print(f\"  응답: [{' '.join(f'{b:02X}' for b in r)}]\")\n            if r[1] == 0x6F:\n                print(\"  IOControl 성공\")\n            elif r[1] == 0x7F:\n                nrc = r[3] if len(r)>3 else 0\n                print(f\"  거부 NRC=0x{nrc:02X}\")\n                return\n        else:\n            print(\"  타임아웃\"); return\n\n        # 3단 상태 확인 (3초 대기 후)\n        monitor(5, \"3단 ON 후\")\n\n        # 자동 하강 모니터링 (최대 90초)\n        print(\"\\n  === 자동 하강 모니터링 (최대 90초) ===\")\n        monitor(90, \"자동 하강\")\n\n        # 수동 OFF\n        print(\"\\n  === 히터 OFF ===\")\n        r = uds_req([0x04,0x2F,0xF0,0x16,0x00,0,0,0])\n        if r:\n            print(f\"  응답: [{' '.join(f'{b:02X}' for b in r)}]\")\n\n        monitor(3, \"OFF 후\")\n\n    finally:\n        _ign_running = False\n        globals()['_tp_running'] = False\n        time.sleep(0.3)\n        pcan.CAN_Uninitialize(c_uint16(PCAN_USBBUS1))\n        print(\"\\n정리 완료\")\n\nif __name__ == \"__main__\":\n    main()\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"73262ffa-e489-4b0a-b45e-9c23de3cd6a4"}
